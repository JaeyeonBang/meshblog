# build output
dist/
# generated types
.astro/
# Playwright
test-results/
playwright-report/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.local
.env.production
*.log

# macOS-specific files
.DS_Store

# jetbrains setting folder
.idea/

# meshblog: build-time RAG index and generated content caches
.data/
# PGR-3: .data/qa/ is committed to repo (local gen + commit + CI astro-build)
!.data/qa/

# meshblog: local-only assets — do not ship to public repo
raw/                 # `/ingest-raw` source inbox (often contains PII)
public/og/           # OG images regenerated by CI per build
public/avatar.webp   # personal asset, opt-in
!.data/qa/**
public/qa/

# Generated artifacts (Phase 3 T7)
/public/og/*
!/public/og/posts/
/public/atom.xml
/public/notes-manifest.json
/.data/

# Graph JSONs: entity-derived files (note-l*, concept-l*) are committed
# from local builds because CI has no claude CLI to re-extract them.
# Backlinks + categories are still re-generated each CI run (no LLM needed).
/public/graph/backlinks.json
/public/graph/categories.json

# local Obsidian vault if symlinked inside repo
content/.obsidian/

# /init writes this after spawning the dev server; consumed for cleanup
.init-dev.pid

.gstack/

# Phase 2 ingest pipeline — drop raw files into _inbox/, archived to .cache/sources/
_inbox/
.cache/

# graphify: keep the knowledge-graph artifacts so other clones can navigate
# the same graph state without rebuilding. The per-machine extraction cache
# stays ignored — `graphify update .` repopulates it on demand.
graphify-out/cache/
CLAUDE.md.pre-graphify.bak
