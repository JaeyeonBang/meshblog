# Required for embeddings (text-embedding-3-small).
# Optional — omit to fall back to fixture mode.
OPENAI_API_KEY=sk-...

# All LLM-driven scripts (ingest-raw, draft-post, concept naming, entity
# extraction, Q&A generation) shell out to the local `claude -p` CLI, so no
# additional API key is needed. Make sure the `claude` binary is on PATH:
#   https://docs.anthropic.com/claude-code
