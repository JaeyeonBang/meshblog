---
// Base.astro — shared HTML shell for all meshblog pages
//
// Props:
//   title       — page <title> (required)
//   description — meta description (defaults to site tagline)
//   ogImage     — relative or absolute OG image path (defaults to /og/index.png)
//   lang        — html[lang] override; auto-detected via AF1 heuristic if omitted

import '../styles/tokens.css'
import '../styles/fonts.css'

export interface Props {
  title: string
  description?: string
  ogImage?: string
  lang?: 'ko' | 'en'
}

const {
  title,
  description = 'meshblog: personal 2nd brain',
  ogImage = '/og/index.png',
  lang: langProp,
} = Astro.props

// AF1 — lang heuristic: infer from Korean vs Latin char density
function inferLang(content: unknown): 'ko' | 'en' {
  const s = typeof content === 'string' ? content : JSON.stringify(content ?? '')
  const koChars = (s.match(/[\uAC00-\uD7AF]/g) || []).length
  const enChars = (s.match(/[A-Za-z]/g) || []).length
  return koChars > enChars ? 'ko' : 'en'
}

const lang = langProp ?? inferLang(title + ' ' + description)

const siteBase = Astro.site ?? new URL('https://jaeyeonbang.github.io')
const canonicalUrl = new URL(Astro.url.pathname, siteBase).toString()
// Prefix base path for public/ assets (e.g. /meshblog/og/index.png)
const BASE = import.meta.env.BASE_URL.replace(/\/$/, '')
const ogImagePath = ogImage.startsWith('http') ? ogImage : `${BASE}${ogImage}`
const ogImageUrl = new URL(ogImagePath, siteBase).toString()
const atomHref = `${BASE}/atom.xml`
const faviconHref = `${BASE}/favicon.svg`
const fontPreloadHref = `${BASE}/fonts/Pretendard-Regular.subset.91.woff2`
const navHome = `${BASE}/`
const navGraph = `${BASE}/graph`
const navAbout = `${BASE}/about`
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href={fontPreloadHref}
      crossorigin
    />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalUrl} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- Atom feed -->
    <link rel="alternate" type="application/atom+xml" href={atomHref} title="meshblog posts" />

    <style is:global>
      /* ── Accessibility utilities ──────────────────────────────────── */

      .sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
      }
      .sr-only-focusable:focus,
      .sr-only-focusable:focus-visible {
        position: static;
        width: auto;
        height: auto;
        margin: 0;
        overflow: visible;
        clip: auto;
        white-space: normal;
      }

      /* ── Global layout reset ──────────────────────────────────────── */

      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        background: var(--meshblog-color-bg);
        color: var(--meshblog-color-text-primary);
        font-family: var(--meshblog-font-sans);
        font-size: var(--meshblog-font-size-md);
        line-height: 1.6;
      }

      /* ── Header / nav ─────────────────────────────────────────────── */

      body > header {
        background: var(--meshblog-color-bg);
      }

      body > header nav {
        display: flex;
        align-items: center;
        max-width: 1120px;
        margin-inline: auto;
        padding: var(--meshblog-space-4) var(--meshblog-space-4);
      }

      @media (min-width: 768px) {
        body > header nav {
          padding: var(--meshblog-space-5) var(--meshblog-space-6);
        }
      }

      /* Wordmark — serif, left side */
      body > header nav .nav-wordmark {
        font-family: var(--meshblog-font-serif);
        font-size: var(--meshblog-font-size-xl);
        font-weight: 500;
        letter-spacing: -0.015em;
        color: var(--meshblog-color-text-primary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        line-height: 1;
      }

      body > header nav .nav-wordmark:hover {
        color: var(--meshblog-color-text-primary);
      }

      /* Nav links group — pushed to the right */
      body > header nav .nav-links {
        display: flex;
        align-items: center;
        gap: var(--meshblog-space-6);
        margin-left: auto;
      }

      body > header nav .nav-links a {
        font-family: var(--meshblog-font-sans);
        font-size: var(--meshblog-font-size-sm);
        color: var(--meshblog-color-text-secondary);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        min-height: 44px;
        transition: color var(--meshblog-dur-fast) var(--meshblog-ease);
      }

      body > header nav .nav-links a:hover {
        color: var(--meshblog-color-text-primary);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: var(--meshblog-color-accent);
      }

      body > header nav a:focus-visible {
        outline: 2px solid var(--meshblog-color-focus-ring);
        outline-offset: 2px;
        border-radius: var(--meshblog-radius-sm);
      }

      /* Hair rule below header — let whitespace do most of the work */
      body > header::after {
        content: '';
        display: block;
        height: 1px;
        background: var(--meshblog-color-rule);
        max-width: 1120px;
        margin-inline: auto;
        margin-inline-start: var(--meshblog-space-4);
        margin-inline-end: var(--meshblog-space-4);
      }

      @media (min-width: 768px) {
        body > header::after {
          margin-inline-start: var(--meshblog-space-6);
          margin-inline-end: var(--meshblog-space-6);
        }
      }

      /* ── Footer ───────────────────────────────────────────────────── */

      body > footer {
        margin-top: var(--meshblog-space-24);
        padding: var(--meshblog-space-8) var(--meshblog-space-6);
        text-align: center;
        color: var(--meshblog-color-muted);
      }

      body > footer::before {
        content: '';
        display: block;
        height: 1px;
        background: var(--meshblog-color-rule);
        max-width: 320px;
        margin-inline: auto;
        margin-bottom: var(--meshblog-space-8);
      }

      body > footer .footer-mark {
        font-family: var(--meshblog-font-serif);
        font-size: var(--meshblog-font-size-sm);
        font-style: italic;
        letter-spacing: 0.01em;
        color: var(--meshblog-color-muted);
        display: block;
        margin-bottom: var(--meshblog-space-3);
      }

      body > footer .footer-links {
        font-family: var(--meshblog-font-sans);
        font-size: var(--meshblog-font-size-xs);
        color: var(--meshblog-color-muted);
        letter-spacing: 0.03em;
      }

      body > footer a {
        color: var(--meshblog-color-muted);
        text-decoration: underline;
        text-underline-offset: 2px;
        transition: color var(--meshblog-dur-fast) var(--meshblog-ease);
      }

      body > footer a:hover {
        color: var(--meshblog-color-accent);
        text-decoration-color: var(--meshblog-color-accent);
      }

      body > footer a:focus-visible {
        outline: 2px solid var(--meshblog-color-focus-ring);
        outline-offset: 2px;
        border-radius: var(--meshblog-radius-sm);
      }
    </style>
  </head>
  <body>
    <!-- AF6 skip link for keyboard/screen-reader users -->
    <a href="#main" class="sr-only sr-only-focusable">Skip to main content</a>

    <header>
      <nav aria-label="primary">
        <a href={navHome} class="nav-wordmark">meshblog</a>
        <div class="nav-links">
          <a href={navGraph}>graph</a>
          <a href={navAbout}>about</a>
        </div>
      </nav>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer>
      <span class="footer-mark">meshblog &middot; est. 2026</span>
      <span class="footer-links">
        <a href={atomHref}>Atom feed</a>
      </span>
    </footer>
  </body>
</html>
