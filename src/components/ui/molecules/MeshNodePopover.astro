---
/**
 * MeshNodePopover.astro
 * Reusable popover panel that surfaces a neighbour node's metadata.
 * Rendered hidden inside MeshStrip.astro; shown/hidden by MeshStrip's
 * vanilla-JS controller via opacity transition.
 *
 * Props are intentionally flat — no sub-objects — so Wave 2's caller
 * can spread a single mesh-data node object.
 *
 * ARIA pattern — role="tooltip":
 *   This panel is a transient, read-only supplementary preview with NO
 *   interactive content. The correct WAI-ARIA pattern for such an element
 *   is role="tooltip" (ARIA 1.1 §5.4), with the trigger pointing to it via
 *   aria-describedby rather than aria-controls/aria-expanded (which belong
 *   to disclosure widgets and dialogs).
 *
 *   Using role="dialog" with aria-modal="false" was incorrect because screen
 *   readers (NVDA, VoiceOver) treat dialogs as distinct regions and may move
 *   the virtual cursor into them — disruptive for a non-interactive preview.
 *
 *   aria-label is retained on the tooltip element itself because WAI-ARIA
 *   allows tooltips to carry their own accessible name, and it provides a
 *   useful label when the tooltip is discovered via accessibility tree
 *   inspection — separate from the aria-describedby path the trigger uses.
 */
interface Props {
  /** The note/concept title rendered at the top of the popover. */
  title: string
  /** Short excerpt (max ~200 chars recommended; CSS clamps to 3 lines). */
  excerpt?: string
  /** Number of inbound wikilinks pointing to this node. */
  backlinks?: number
  /** Semantic edge type from the viewer's perspective. */
  relationship?: 'backlink' | 'outbound' | 'entity'
  /** Estimated reading time in minutes (0 = <1 min). */
  readingMinutes?: number
  /** Graph node kind — stubs replace excerpt with placeholder prose. */
  kind?: 'hub' | 'concept' | 'selected' | 'note' | 'stub'
  /** Unique id shared with the trigger's aria-controls. */
  id: string
  /** Display title of the owning note — used in aria-label for screen readers. */
  ariaLabel?: string
}

const {
  title,
  excerpt,
  backlinks = 0,
  relationship,
  readingMinutes,
  kind,
  id,
  ariaLabel,
} = Astro.props

const isStub = kind === 'stub'

/* ── Relationship label mapping ─────────────────────────────────────── */
const relLabel: Record<string, string> = {
  backlink: '← BACKLINK',
  outbound: 'OUTBOUND →',
  entity:   'ENTITY OVERLAP',
}
const relText = relationship ? relLabel[relationship] : undefined

/* ── Meta row tokens (only show defined values) ─────────────────────── */
const metaParts: string[] = []
if (relText)                    metaParts.push(relText)
if (backlinks > 0)              metaParts.push(`BACKLINKS ${backlinks}`)
if (readingMinutes !== undefined) metaParts.push(`${Math.max(1, readingMinutes)} MIN`)
---

<div
  id={id}
  class="mesh-popover"
  role="tooltip"
  aria-label={ariaLabel ?? `Note preview: ${title}`}
>
  <p class="popover-title">{title}</p>

  {isStub ? (
    <p class="popover-stub">no content yet · stub note</p>
  ) : excerpt ? (
    <p class="popover-excerpt">{excerpt}</p>
  ) : null}

  {metaParts.length > 0 && (
    <p class="popover-meta">{metaParts.join(' · ')}</p>
  )}
</div>

<style>
  /* ── Popover shell ───────────────────────────────────────────────────
     Invariant #5: var(--shadow-hard) is the ONE allowed shadow in this
     widget. Invariant #6: var(--r-sm) = 2px (≤ 4px cap).
  ──────────────────────────────────────────────────────────────────── */
  .mesh-popover {
    /* Positioning is managed by MeshStrip's JS (absolute, flipped if needed). */
    position: absolute;
    z-index: 20;

    /* Visual spec */
    width: 300px;
    max-width: min(360px, 80vw);

    border: 1px solid var(--ink);
    background: var(--paper);
    box-shadow: var(--shadow-hard);
    border-radius: var(--r-sm);
    padding: var(--space-4);

    /* Fade in/out — JS toggles .is-visible which sets opacity: 1. */
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-fast) var(--ease);
  }

  .mesh-popover.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Reduced-motion: skip the transition; honour OS preference. */
  @media (prefers-reduced-motion: reduce) {
    .mesh-popover {
      transition: none;
    }
  }

  /* ── Title ── Fraunces display, var(--fs-md), var(--ink) ─────────── */
  .popover-title {
    font-family: var(--f-disp);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-2) 0;
    line-height: 1.3;
  }

  /* ── Excerpt ── 3-line clamp ───────────────────────────────────────── */
  .popover-excerpt {
    font-family: var(--f-disp);
    font-size: var(--fs-sm);
    color: var(--ink-2);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.5;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* ── Stub placeholder ─────────────────────────────────────────────── */
  .popover-stub {
    font-family: var(--f-disp);
    font-size: var(--fs-sm);
    font-style: italic;
    color: var(--ink-3);
    margin: 0 0 var(--space-3) 0;
    line-height: 1.5;
  }

  /* ── Meta row ── mono eyebrow, 10px, var(--ink-3), 0.2em tracking ── */
  .popover-meta {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
    line-height: 1.4;
  }
</style>
