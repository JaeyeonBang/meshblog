---
import QaCard from './QaCard.astro';

interface QaItem {
  question: string;
  answer?: string;
  open?: boolean;
}
interface Props {
  scope: 'page' | 'note' | 'global';
  items: QaItem[];
}
const { scope, items } = Astro.props;
const label = scope === 'page' ? 'ask this page' : scope === 'note' ? 'ask this note' : 'ask the vault';
const heading = `QAChips — ${scope} scope`;
---
<div class="page-qa">
  <div class="qa-label">{label}</div>
  <h2>{heading}</h2>
  <div class="qa-list">
    {items.map((item) => (
      <QaCard question={item.question} answer={item.answer} open={item.open} />
    ))}
  </div>
  <slot />
</div>

<style>
  .page-qa {
    margin-top: 56px;
    padding: 36px 0;
    border-top: 3px solid var(--ink);
    border-bottom: 1px solid var(--ink);
  }
  .qa-label {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 4px;
  }
  h2 {
    font-family: var(--f-disp);
    font-weight: 600;
    font-size: var(--fs-3xl);
    margin: 0 0 22px;
    letter-spacing: -0.015em;
  }
  .qa-list {
    display: flex;
    flex-direction: column;
  }
</style>
