---
/**
 * PostSidebar.astro — right 240px aside for post reader pages.
 *
 * CANONICAL ASIDE ORDER for DETAIL pages (single source of truth: design.md
 * → layout.aside-order-detail). Top to bottom:
 *   1. Related-graph  — PostMeshGraph (only when meshNodes.length > 1).
 *   2. Categories     — site-wide list, current post's category highlighted.
 *   3. Tags           — current post's tags in sorted form.
 *   4. Contents (TOC) — scroll-spy table of contents.
 *   5. Concept-graph  — sticky-bottom PostConceptGraph (only when conceptGraph
 *      has nodes). Uses /graph?mode=concept&level=3 visual contract.
 *
 * If you change this order, update BOTH:
 *   - design.md `layout.aside-order-detail`
 *   - notes/[slug].astro inline aside
 *
 * Editorial invariants honoured: #1 no hex, #2 hairline 1px, #3 hover-invert,
 *   #4 mono eyebrow 10px + var(--track-eyebrow) uppercase, #5 no shadow, #6 ≤4px radius.
 */

import TOC from './TOC.astro'
import PostMeshGraph from '../../PostMeshGraph'
import PostConceptGraph from '../../PostConceptGraph'
import { listCategories } from '../../../lib/pages/index'
import type { CategoryRow } from '../../../lib/pages/index'
import type { MeshNode, PostConceptGraph as PostConceptGraphData } from '../../../lib/mesh-data'
import { withBase } from '../../../lib/url'
import { formatCategoryName } from '../../../lib/categories/display-name'

interface TocItem {
  label: string
  level?: 1 | 2
  href?: string
  active?: boolean
}

interface Props {
  /** slug of the current post's category (may be null if uncategorised) */
  currentCategory: string | null
  /** tags on the current post */
  tags: string[]
  /** centre + neighbour nodes for PostMeshGraph */
  meshNodes: MeshNode[]
  /** inter-neighbour edges for PostMeshGraph */
  meshLinks: Array<{ source: string; target: string }>
  /** TOC items extracted from the article HTML */
  tocItems: TocItem[]
  /** current post slug (unused here but forwarded for future use) */
  slug: string
  /** Per-post concept subgraph (sticky-bottom block). Optional — hidden when empty. */
  conceptGraph?: PostConceptGraphData
}

const { currentCategory, tags, meshNodes, meshLinks, tocItems, conceptGraph } = Astro.props

// Show only categories that actually have content. Empty taxonomies (e.g.
// "design", "personal") generate dead /categories/<slug>/ links because
// getStaticPaths in src/pages/categories/[slug].astro only emits routes for
// categories with rows. Surfacing them produced 4 × 404s on every post page.
//
// Includes the current post's category even when the DB returns 0 for it,
// since getStaticPaths still emitted the route (the post itself counts).
const allCategories: CategoryRow[] = listCategories()
const categories: CategoryRow[] = allCategories.filter(
  (c) => (c.noteCount + c.postCount) > 0 || c.slug === Astro.props.currentCategory,
)

// Sort tags alphabetically for stable ordering
const sortedTags = [...tags].sort()
---

<!-- ── Related mesh (conditional) ────────────────────────────────────────── -->
{meshNodes.length > 1 && (
  <section class="sidebar-section related-mesh-section" aria-label="related mesh">
    <div class="section-label">related</div>
    <PostMeshGraph nodes={meshNodes} links={meshLinks} client:visible />
    <a class="mesh-cta" href={withBase('/graph')}>full graph →</a>
  </section>
)}

<!-- ── Categories ─────────────────────────────────────────────────────────── -->
<section class="sidebar-section" aria-label="categories">
  <div class="section-label">categories</div>
  <ul class="cat-list" role="list">
    {categories.map((cat) => (
      <li class:list={['cat-item', currentCategory === cat.slug && 'active']}>
        <a href={withBase(`/categories/${cat.slug}/`)} class="cat-link">
          <span class="cat-name">{formatCategoryName(cat.slug, cat.name)}</span>
          {(cat.noteCount + cat.postCount) > 0 && (
            <span class="cat-count">&middot; {cat.noteCount + cat.postCount}</span>
          )}
        </a>
      </li>
    ))}
  </ul>
</section>

<!-- ── Tags ───────────────────────────────────────────────────────────────── -->
{sortedTags.length > 0 && (
  <section class="sidebar-section" aria-label="tags">
    <div class="section-label">tags</div>
    <div class="tag-cloud">
      {sortedTags.map((tag) => (
        <a class="sidebar-tag" href={`${withBase('/posts')}?tag=${encodeURIComponent(tag)}`}>{tag}</a>
      ))}
    </div>
  </section>
)}

<!-- ── TOC ────────────────────────────────────────────────────────────────── -->
<TOC label="contents" items={tocItems} />

<!-- ── Sticky concept graph (Task 7-2) ──────────────────────────────────── -->
{/* Hide the section unless the graph is non-degenerate: ≥2 nodes AND ≥1 link.
    Two unconnected circles read as broken; same gate as the article-header
    toggle in posts/[slug].astro. */}
{conceptGraph && conceptGraph.nodes.length > 1 && conceptGraph.links.length > 0 && (
  <section class="sidebar-section sticky-concept-section" aria-label="post concept graph">
    <div class="section-label">concepts in this post</div>
    <PostConceptGraph
      nodes={conceptGraph.nodes}
      links={conceptGraph.links}
      client:visible
    />
    <p class="concept-meta">{conceptGraph.nodes.length} concepts · {conceptGraph.links.length} links</p>
  </section>
)}

<style>
  /* ── Shared section chrome ─────────────────────────────────────────────── */
  .sidebar-section {
    margin-bottom: 36px;
  }

  .section-label {
    font-family: var(--f-mono);
    font-size: var(--fs-xxs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    padding-bottom: 8px;
    margin-bottom: 10px;
    border-bottom: 1px solid var(--ink);
    font-weight: 400;
  }

  /* ── Category list ─────────────────────────────────────────────────────── */
  .cat-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .cat-item {
    border-bottom: 1px solid var(--rule-soft);
  }

  .cat-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: 6px 0;
    text-decoration: none;
    color: var(--ink-3);
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }

  /* hover-invert: ink bg, paper text */
  .cat-link:hover {
    background: var(--ink);
    color: var(--paper);
    padding-left: 8px;
    margin-left: -8px;
    padding-right: 8px;
    margin-right: -8px;
  }

  .cat-link:hover .cat-count {
    color: var(--paper-2);
  }

  .cat-link:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Active state: same invert treatment as hover */
  .cat-item.active .cat-link {
    background: var(--ink);
    color: var(--paper);
    padding-left: 8px;
    margin-left: -8px;
    padding-right: 8px;
    margin-right: -8px;
  }

  .cat-item.active .cat-count {
    color: var(--paper-2);
  }

  .cat-name {
    font-family: var(--f-serif);
    font-size: var(--fs-sm);
    line-height: 1.3;
  }

  .cat-count {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    letter-spacing: var(--track-caption);
    transition: color var(--dur-fast) var(--ease);
  }

  /* ── Tag cloud ─────────────────────────────────────────────────────────── */
  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .sidebar-tag {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    font-weight: 700;
    padding: 2px 8px 3px;
    color: var(--ink-2);
    border-bottom: 1px solid var(--ink-5);
    display: inline-block;
    line-height: 1.4;
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease), border-color var(--dur-fast) var(--ease);
  }
  /* Hover-invert (editorial invariant #3) */
  .sidebar-tag:hover {
    background: var(--ink);
    color: var(--paper);
    border-bottom-color: var(--ink);
  }
  .sidebar-tag:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* ── Related mesh ──────────────────────────────────────────────────────── */
  .mesh-cta {
    display: block;
    margin-top: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  .mesh-cta:hover {
    color: var(--ink);
  }

  .mesh-cta:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Hide graph on mobile; rest stays in flow */
  @media (max-width: 779px) {
    .related-mesh-section {
      display: none;
    }
  }

  /* ── Sticky concept graph (Task 7-2) ──────────────────────────────────── */
  .sticky-concept-section {
    /* class name retained to avoid markup churn — the section is now in normal flow */
    margin-top: var(--space-8);
    padding-top: var(--space-3);
    border-top: 1px solid var(--rule-soft);
  }

  .concept-meta {
    margin: var(--space-2) 0 0;
    font-family: var(--f-mono);
    font-size: var(--fs-xxs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
  }

  @media (max-width: 779px) {
    .sticky-concept-section {
      display: none;
    }
  }
</style>
