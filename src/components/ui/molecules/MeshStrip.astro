      kind: 'concept',
      excerpt: 'A slip-box system for building a personal knowledge network through atomic, linked notes.',
      backlinks: 14,
      relationship: 'outbound',
      readingMinutes: 4,
    },
    {
      label: 'Fleeting Notes',
      href: '/meshblog/notes/fleeting-notes',
      kind: 'note',
      excerpt: 'Raw captures before they are processed and turned into permanent notes.',
      backlinks: 6,
