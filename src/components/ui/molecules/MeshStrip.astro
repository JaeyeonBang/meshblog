---
/**
 * MeshStrip.astro
 * Full-width mesh-navigation band placed ABOVE the article prose.
 * Replaces the canvas-style MiniMesh.astro with a typographic,
 * keyboard-accessible, popover-enabled layout.
 *
 * Layout:
 *   [ CENTER LABEL ]  ·  NEIGHBOR A  ·  NEIGHBOR B  ·  NEIGHBOR C …
 *
 * Interaction model (desktop ≥780px):
 *   - Hover / focus a neighbor → 140 ms delayed fade-in popover below trigger.
 *   - Leave / blur → 140 ms fade-out.
 *   - Esc while a popover is open → close, keep focus on trigger.
 *   - Click → native <a> navigation (no JS needed).
 *
 * Interaction model (mobile <780px):
 *   - NO floating popover.
 *   - Tap neighbor → toggles an inline-expanded card below the strip row.
 *   - Tap outside → collapse.
 *
 * Deliberate design decision — TYPOGRAPHIC HOVER (not bg-flip):
 *   Neighbor labels use color → var(--ink) + font-weight 600 on hover/focus,
 *   NOT a background-color flip. This mirrors Obsidian Publish's TOC active-
 *   state pattern and was chosen because the strip is a wayfinding aid rather
 *   than a button surface. The conventional hover-invert (paper ↔ ink bg swap)
 *   is preserved for button/interactive-surface elements elsewhere in the system.
 */

import MeshNodePopover from './MeshNodePopover.astro'

interface Node {
  label: string
  href?: string
  kind?: 'hub' | 'concept' | 'selected' | 'note' | 'stub'
  excerpt?: string
  backlinks?: number
  relationship?: 'backlink' | 'outbound' | 'entity'
  readingMinutes?: number
}
type Props = {
  nodes: Node[]   // index 0 is center; indices 1..N are neighbors
}

const { nodes } = Astro.props
const [center, ...neighbors] = nodes
---

<div class="mesh-strip" data-mesh-strip>
  {/* ── Strip row ──────────────────────────────────────────────────── */}
  <div class="strip-row">
    {/* Center node — not interactive, excluded from tab order */}
    <span class="center-label" aria-current="page" tabindex="-1">
      {center?.label ?? ''}
    </span>

    {neighbors.length > 0 && (
      <span class="strip-divider" aria-hidden="true">·</span>
    )}

    {/* Neighbor nodes */}
    {neighbors.map((node: Node, idx: number) => {
      const popoverId = `mesh-popover-${idx}`
      const isStub = node.kind === 'stub'

      return (
        <span class="neighbor-wrap" data-mesh-wrap>
          {node.href ? (
            <a
              href={node.href}
              class:list={['neighbor-label', isStub && 'neighbor-label--stub']}
              data-mesh-trigger
              aria-describedby={popoverId}
            >
              {node.label}
            </a>
          ) : (
            <span
              class:list={['neighbor-label', isStub && 'neighbor-label--stub']}
              data-mesh-trigger
              aria-describedby={popoverId}
              tabindex="0"
            >
              {node.label}
            </span>
          )}

          {/* Popover — hidden at rest; JS flips .is-visible */}
          <MeshNodePopover
            id={popoverId}
            title={node.label}
            excerpt={node.excerpt}
            backlinks={node.backlinks}
            relationship={node.relationship}
            readingMinutes={node.readingMinutes}
            kind={node.kind}
            ariaLabel={`Note preview: ${node.label}`}
          />
        </span>
      )
    })}
  </div>

  {/* ── Mobile inline expansion area ─────────────────────────────────
      JS populates this with a clone of the active popover's content.
  ──────────────────────────────────────────────────────────────────── */}
  <div class="mobile-expand" data-mesh-mobile-expand aria-live="polite" hidden></div>
</div>

<style>
  /* ── Strip container ──────────────────────────────────────────────── */
  .mesh-strip {
    width: 100%;
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    background: var(--paper);
    padding: var(--space-3) 0;
    /* Aim for 80–100px height; min-height prevents collapse when empty */
    min-height: 80px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  /* ── Strip row (center + neighbors) ──────────────────────────────── */
  .strip-row {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-3);
  }

  /* ── Center label ─────────────────────────────────────────────────── */
  .center-label {
    font-family: var(--f-disp);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--ink);
    /* Not clickable — remove from interactive/tab flow */
    pointer-events: none;
    user-select: none;
    line-height: 1;
  }

  /* ── Divider dot ─────────────────────────────────────────────────── */
  .strip-divider {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    flex-shrink: 0;
  }

  /* ── Neighbor wrapper (positions the popover) ─────────────────────── */
  .neighbor-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
  }

  /* ── Neighbor label ── mono eyebrow style at rest ─────────────────
     Invariant #3 (deliberate exception):
       This widget uses TYPOGRAPHIC hover (color + weight shift), not
       the usual hover-invert (bg ↔ ink flip). See header comment.
     Invariant #4: var(--f-mono) + letter-spacing 0.2em + 10–11px + var(--ink-3).
  ──────────────────────────────────────────────────────────────────── */
  .neighbor-label {
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    text-decoration: none;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    line-height: 1;
    transition: color var(--dur-fast) var(--ease), font-weight var(--dur-fast) var(--ease);
  }

  /* Hover / focus — typographic shift only (no background change) */
  .neighbor-label:hover,
  .neighbor-label:focus-visible {
    color: var(--ink);
    font-weight: 600;
    outline: none;
  }

  /* Explicit focus ring for accessibility */
  .neighbor-label:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 3px;
    border-radius: var(--r-sm);
  }

  /* Stub modifier: dotted underline + reduced opacity */
  .neighbor-label--stub {
    text-decoration: underline dotted var(--ink-3);
    opacity: 0.7;
  }
  .neighbor-label--stub:hover,
  .neighbor-label--stub:focus-visible {
    opacity: 1;
  }

  /* ── Mobile expand area ──────────────────────────────────────────── */
  .mobile-expand {
    margin-top: var(--space-3);
    border: 1px solid var(--ink);
    background: var(--paper);
    padding: var(--space-4);
    /* Width mirrors popover spec at mobile scale */
    max-width: 80vw;
  }

  /* CTA appended inside the mobile inline card by JS (expandMobile).
     Keeps mobile users from getting stuck on the preview without a
     visible path to the linked note. Hover-invert per invariant #3. */
  .mobile-expand :global(.mobile-expand-cta) {
    display: inline-block;
    margin-top: var(--space-3);
    padding: var(--space-2) var(--space-3);
    min-height: 44px;
    line-height: 28px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--ink);
    text-decoration: none;
    transition: background var(--dur-fast) var(--ease), color var(--dur-fast) var(--ease);
  }
  .mobile-expand :global(.mobile-expand-cta):hover,
  .mobile-expand :global(.mobile-expand-cta):focus-visible {
    background: var(--ink);
    color: var(--paper);
    outline: none;
  }
  .mobile-expand :global(.mobile-expand-cta):focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* ── Mobile: enlarge neighbor tap target to meet WCAG 2.5.5 ───────
     At rest the desktop label is a 11px mono eyebrow — fine for cursor
     pointing, but a 11×N px touch target violates WCAG 2.5.5 (≥44×44).
     On <780px viewports we bump to 12px with vertical padding +
     min-height: 44px so taps land reliably (review CONCERN-2). The
     mono-eyebrow visual character is preserved.
     Popover suppression on mobile is handled by the isMobile() JS guard.
  ─────────────────────────────────────────────────────────────────── */
  @media (max-width: 780px) {
    .neighbor-label {
      font-size: 12px;
      line-height: 1.3;
      padding: var(--space-3) var(--space-2);
      min-height: 44px;
      display: inline-flex;
      align-items: center;
    }
  }
</style>

<script>
  /**
   * MeshStrip interactive controller (vanilla JS, no framework deps).
   *
   * Responsibilities:
   *   1. Desktop: hover/focus → delayed-fade popover; blur/leave → fade out.
   *   2. Desktop: Esc → close active popover, restore focus.
   *   3. Desktop: popover flip — opens above trigger when too close to viewport bottom.
   *   4. Mobile (<780px): tap trigger → inline expand; tap outside → collapse.
   *   5. Reduced-motion: no delay, instant show/hide.
   */
  (function initMeshStrip() {
    const DELAY   = 140   // ms — matches var(--dur-fast)
    const MOBILE  = 780   // px breakpoint

    const isMobile = () => window.matchMedia(`(max-width: ${MOBILE}px)`).matches
    const reducedMotion = () =>
      window.matchMedia('(prefers-reduced-motion: reduce)').matches

    /**
     * One controller per `.mesh-strip` instance (supports multiple strips
     * on a single page, e.g. post + note layouts).
     */
    function mountStrip(strip: HTMLElement) {
      const triggers  = Array.from(
        strip.querySelectorAll<HTMLElement>('[data-mesh-trigger]')
      )
      const mobileBox = strip.querySelector<HTMLElement>('[data-mesh-mobile-expand]')

      let activePopover: HTMLElement | null = null
      let activeTrigger: HTMLElement | null = null
      let showTimer: ReturnType<typeof setTimeout> | null = null
      let hideTimer: ReturnType<typeof setTimeout> | null = null
      let escListener: ((e: KeyboardEvent) => void) | null = null

      /* ── Helpers ──────────────────────────────────────────────── */

      function clearTimers() {
        if (showTimer) { clearTimeout(showTimer); showTimer = null }
        if (hideTimer) { clearTimeout(hideTimer); hideTimer = null }
      }

      function getPopover(trigger: HTMLElement): HTMLElement | null {
        const id = trigger.getAttribute('aria-describedby')
        if (!id) return null
        return document.getElementById(id)
      }

      /**
       * Reposition popover relative to its trigger.
       * Priority order:
       *   1. Vertical flip: open above trigger when too close to viewport bottom.
       *   2. Horizontal flip: anchor to right edge of trigger when left-anchored
       *      popover would overflow the right side of the viewport.
       * The CSS max-width cap handles the residual case where even right-edge
       * anchoring overflows (very narrow viewport with a wide popover).
       */
      function positionPopover(trigger: HTMLElement, popover: HTMLElement) {
        // Reset all inline offsets to defaults before measuring.
        popover.style.top    = ''
        popover.style.bottom = ''
        popover.style.left   = '0'
        popover.style.right  = ''

        // ── 1. Vertical flip ────────────────────────────────────────────
        const tRect = trigger.getBoundingClientRect()
        const pHeight = popover.offsetHeight || 200
        const spaceBelow = window.innerHeight - tRect.bottom

        if (spaceBelow < pHeight + 8) {
          // Flip above
          popover.style.bottom = '100%'
          popover.style.top    = 'auto'
          popover.style.marginTop = '0'
          popover.style.marginBottom = 'var(--space-2)'
        } else {
          popover.style.top    = '100%'
          popover.style.bottom = 'auto'
          popover.style.marginTop = 'var(--space-2)'
          popover.style.marginBottom = '0'
        }

        // ── 2. Horizontal flip ───────────────────────────────────────────
        // Re-measure after vertical placement so offsetWidth is stable.
        const pWidth = popover.offsetWidth || 300
        const viewportWidth = window.innerWidth
        const MARGIN = 8

        if (tRect.left + pWidth > viewportWidth - MARGIN) {
          // Popover would overflow right edge — anchor to trigger's right side instead.
          popover.style.left  = 'auto'
          popover.style.right = '0'
        }
        // Otherwise the default left:'0' set above is already correct.
      }

      function showPopover(trigger: HTMLElement) {
        const popover = getPopover(trigger)
        if (!popover) return

        // Close any other active popover first
        if (activePopover && activePopover !== popover) {
          hidePopoverNow(activePopover, activeTrigger)
        }

        activePopover  = popover
        activeTrigger  = trigger

        positionPopover(trigger, popover)
        popover.classList.add('is-visible')

        // Attach Esc listener (only while a popover is open)
        if (!escListener) {
          escListener = (e: KeyboardEvent) => {
            if (e.key === 'Escape' && activePopover) {
              e.preventDefault()
              hidePopoverNow(activePopover, activeTrigger)
              activeTrigger?.focus()
            }
          }
          document.addEventListener('keydown', escListener)
        }
      }

      function hidePopoverNow(popover: HTMLElement, _trigger: HTMLElement | null) {
        popover.classList.remove('is-visible')
        activePopover = null
        activeTrigger = null
        if (escListener) {
          document.removeEventListener('keydown', escListener)
          escListener = null
        }
      }

      function scheduleShow(trigger: HTMLElement) {
        clearTimers()
        const delay = reducedMotion() ? 0 : DELAY
        showTimer = setTimeout(() => showPopover(trigger), delay)
      }

      function scheduleHide() {
        clearTimers()
        const delay = reducedMotion() ? 0 : DELAY
        hideTimer = setTimeout(() => {
          if (activePopover) hidePopoverNow(activePopover, activeTrigger)
        }, delay)
      }

      /* ── Mobile inline expand ─────────────────────────────────── */

      function expandMobile(trigger: HTMLElement) {
        if (!mobileBox) return
        const id = trigger.getAttribute('aria-describedby')
        const source = id ? document.getElementById(id) : null
        if (!source) { collapseMobile(); return }

        // Clone the popover content (strip position/opacity styles)
        const clone = source.cloneNode(true) as HTMLElement
        clone.removeAttribute('id')
        clone.removeAttribute('role')
        clone.removeAttribute('aria-label')
        clone.style.cssText = ''        // clear inline position styles
        clone.classList.remove('is-visible')
        // Remove the absolute-positioning class; display inline
        clone.style.position = 'static'
        clone.style.opacity  = '1'
        clone.style.boxShadow = 'none'
        clone.style.border    = 'none'
        clone.style.padding   = '0'

        // Append a navigation hint link inside the inline card so users
        // who don't intuit the "second-tap to navigate" pattern still
        // have a clearly tappable path to the target note.
        const href = (trigger as HTMLAnchorElement).href
        if (href) {
          const cta = document.createElement('a')
          cta.href = href
          cta.className = 'mobile-expand-cta'
          cta.textContent = '글 열기 →'
          clone.appendChild(cta)
        }

        mobileBox.innerHTML = ''
        mobileBox.appendChild(clone)
        mobileBox.hidden = false
        activeTrigger = trigger
      }

      function collapseMobile() {
        if (!mobileBox) return
        mobileBox.hidden = true
        mobileBox.innerHTML = ''
        activeTrigger = null
      }

      /* ── Event wiring ─────────────────────────────────────────── */

      triggers.forEach((trigger) => {
        // Desktop: hover
        trigger.addEventListener('mouseenter', () => {
          if (isMobile()) return
          scheduleShow(trigger)
        })
        trigger.addEventListener('mouseleave', () => {
          if (isMobile()) return
          scheduleHide()
        })

        // Desktop: focus / blur (keyboard nav)
        trigger.addEventListener('focus', () => {
          if (isMobile()) return
          scheduleShow(trigger)
        })
        trigger.addEventListener('blur', () => {
          if (isMobile()) return
          scheduleHide()
        })

        // Mobile: first tap shows preview (suppress nav), second tap on
        // the same trigger lets the native <a href> follow. Tap-outside
        // (handled below) collapses without navigating. Mirrors Obsidian
        // mobile's preview→navigate pattern. Without this, the inline-
        // expand card has no path to the linked note (review CONCERN-1).
        trigger.addEventListener('click', (e) => {
          if (!isMobile()) return
          if (activeTrigger === trigger) {
            // Second tap on the active trigger → allow native navigation.
            return
          }
          const href = (trigger as HTMLAnchorElement).href
          if (href) e.preventDefault()
          expandMobile(trigger)
        })
      })

      // Mobile: tap outside strip → collapse
      document.addEventListener('click', (e) => {
        if (!isMobile()) return
        if (!strip.contains(e.target as Node)) {
          collapseMobile()
        }
      })

      // Keep popovers from capturing mouseleave when cursor moves into popover
      strip.querySelectorAll<HTMLElement>('[data-mesh-strip] [id^="mesh-popover-"]')
        .forEach((popover) => {
          popover.addEventListener('mouseenter', () => {
            if (isMobile()) return
            clearTimers() // cancel pending hide while hovering the popover itself
          })
          popover.addEventListener('mouseleave', () => {
            if (isMobile()) return
            scheduleHide()
          })
        })
    }

    function init() {
      document.querySelectorAll<HTMLElement>('[data-mesh-strip]').forEach(mountStrip)
    }

    document.addEventListener('DOMContentLoaded', init)
    document.addEventListener('astro:page-load', init)
  })()
</script>

