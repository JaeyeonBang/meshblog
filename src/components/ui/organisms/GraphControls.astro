---
interface Props {
  mode: 'notes' | 'concepts';
  level: 1 | 2 | 3;
  nodeCount?: number;
  edgeCount?: number;
}
const { mode, level, nodeCount = 0, edgeCount = 0 } = Astro.props;
---
<div class="graph-controls">
  <div class="controls-row">
    <div class="group">
      <span class="lab" id="mode-label">mode</span>
      <div class="btn-group" role="radiogroup" aria-labelledby="mode-label">
        <button
          class:list={['seg', mode === 'notes' && 'seg--active']}
          data-mode="notes"
          role="radio"
          aria-checked={mode === 'notes'}
        >notes</button>
        <button
          class:list={['seg', mode === 'concepts' && 'seg--active']}
          data-mode="concepts"
          role="radio"
          aria-checked={mode === 'concepts'}
        >concepts</button>
      </div>
    </div>

    <div class="group">
      <span class="lab" id="level-label">level</span>
      <div class="btn-group" role="radiogroup" aria-labelledby="level-label">
        {([1, 2, 3] as const).map((l) => (
          <button
            class:list={['seg', level === l && 'seg--active']}
            data-level={l}
            role="radio"
            aria-checked={level === l}
          >L{l}</button>
        ))}
      </div>
    </div>

    <div class="spacer"></div>

    <span class="stats" id="gcStats" aria-live="polite">
      {nodeCount} nodes · {edgeCount} edges
    </span>

    <button class="action-btn" id="gcShareBtn" aria-label="Share graph link">share link</button>
    <button class="action-btn" id="gcListBtn" aria-label="Switch to list view">list view</button>
  </div>
</div>

<style>
  .graph-controls {
    border-bottom: 1px solid var(--ink);
    padding: 0;
    margin-bottom: var(--space-6);
  }

  .controls-row {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    align-items: center;
    padding: var(--space-3) 0;
  }

  .group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* mono eyebrow label */
  .lab {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-3);
    user-select: none;
  }

  /* segment button group — borderless cluster with outer 1px frame */
  .btn-group {
    display: flex;
    border: 1px solid var(--ink);
  }

  .seg {
    border: 0;
    background: transparent;
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    padding: 6px 14px;
    color: var(--ink-3);
    cursor: pointer;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border-right: 1px solid var(--ink);
    /* bottom border reserved for active emphasis */
    border-bottom: 3px solid transparent;
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease),
      border-bottom-color var(--dur-fast) var(--ease);
    line-height: 1;
  }

  .seg:last-child {
    border-right: 0;
  }

  /* Active: invert + 3px bottom emphasis */
  .seg--active {
    background: var(--ink);
    color: var(--paper);
    border-bottom-color: var(--ink);
  }

  /* Hover: full invert (not subtle opacity) */
  .seg:hover:not(.seg--active) {
    background: var(--ink);
    color: var(--paper);
  }

  .seg:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }

  /* spacer pushes stats + action buttons to right */
  .spacer {
    flex: 1;
  }

  /* inline stats — mono eyebrow style */
  .stats {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.1em;
    color: var(--ink-3);
    white-space: nowrap;
  }

  /* action buttons */
  .action-btn {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    padding: 6px 12px;
    border: 1px solid var(--ink);
    cursor: pointer;
    background: var(--paper);
    color: var(--ink);
    border-radius: var(--r-xs);
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }

  .action-btn:hover {
    background: var(--ink);
    color: var(--paper);
  }

  .action-btn:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
</style>
