---
interface Props {
  mode: 'note' | 'concept' | 'backlinks';
  level: 1 | 2 | 3;
  nodeCount?: number;
  edgeCount?: number;
}
const { mode, level, nodeCount = 0, edgeCount = 0 } = Astro.props;

const levelLabels: Record<1 | 2 | 3, { label: string; title: string }> = {
  1: { label: 'L1 · 카테고리 overview', title: 'top-level categories' },
  2: { label: 'L2 · 포스트 in category', title: 'posts within selected category' },
  3: { label: 'L3 · 노트 in category', title: 'individual notes within selected category' },
}
---
<div class="graph-controls">
  <div class="controls-row">
    <div class="group">
      <span class="lab" id="mode-label">mode</span>
      <div class="btn-group" role="radiogroup" aria-labelledby="mode-label">
        <button
          class:list={['seg', mode === 'note' && 'seg--active']}
          data-mode="note"
          role="radio"
          aria-checked={mode === 'note'}
          title="notes = articles"
        >notes</button>
        <button
          class:list={['seg', mode === 'concept' && 'seg--active']}
          data-mode="concept"
          role="radio"
          aria-checked={mode === 'concept'}
          title="concepts = extracted ideas"
        >concepts</button>
        <button
          class:list={['seg', mode === 'backlinks' && 'seg--active']}
          data-mode="backlinks"
          role="radio"
          aria-checked={mode === 'backlinks'}
          title="backlinks = inbound wikilink graph"
        >backlinks</button>
      </div>
    </div>

    <button
      class="disclosure"
      id="gcDepthToggle"
      type="button"
      aria-expanded="true"
      aria-controls="level-group"
      title="카테고리 계층으로 드릴다운"
    >− depth</button>

    <div class="group" id="level-group">
      <span class="lab" id="level-label">level</span>
      <div class="btn-group" role="radiogroup" aria-labelledby="level-label">
        {([1, 2, 3] as const).map((l) => (
          <button
            class:list={['seg', level === l && 'seg--active']}
            data-level={l}
            role="radio"
            aria-checked={level === l}
            title={levelLabels[l].title}
          >{levelLabels[l].label}</button>
        ))}
      </div>
    </div>

    <div class="spacer"></div>

    <span class="stats" id="gcStats" aria-live="polite">
      {nodeCount} nodes · {edgeCount} edges
    </span>

    <div class="overflow" id="gcOverflow">
      <button
        class="overflow-trigger"
        id="gcOverflowBtn"
        type="button"
        aria-haspopup="true"
        aria-expanded="false"
        aria-label="More actions"
        title="share · list view"
      >⋯</button>
      <div class="overflow-menu" id="gcOverflowMenu" role="menu" hidden>
        <button class="overflow-item" id="gcShareBtn" role="menuitem" title="Copy a link to the current view">share link</button>
        <button class="overflow-item" id="gcListBtn" role="menuitemcheckbox" aria-checked="false" title="Switch canvas ↔ flat list">list view</button>
      </div>
    </div>
  </div>
  <p class="level-caption">Level · 카테고리 계층으로 드릴다운</p>
  <span id="gcShareStatus" role="status" aria-live="polite" class="sr-only"></span>
</div>

<script>
  // Depth disclosure — collapsed by default so the graph canvas meets the
  // ≤4 visible-controls cognitive-load gate on first paint. Level seg reveals
  // only after the user opts in.
  function initGraphControlsChrome() {
    const depthBtn = document.getElementById('gcDepthToggle') as HTMLButtonElement | null
    const levelGroup = document.getElementById('level-group')
    const levelCaption = document.querySelector<HTMLElement>('.graph-controls .level-caption')
    if (depthBtn && levelGroup) {
      depthBtn.addEventListener('click', () => {
        const open = depthBtn.getAttribute('aria-expanded') === 'true'
        const next = !open
        depthBtn.setAttribute('aria-expanded', String(next))
        levelGroup.hidden = !next
        if (levelCaption) levelCaption.hidden = !next
        depthBtn.textContent = next ? '− depth' : '+ depth'
      })
    }

    // Overflow menu — share + list live here now.
    const ovBtn = document.getElementById('gcOverflowBtn') as HTMLButtonElement | null
    const ovMenu = document.getElementById('gcOverflowMenu') as HTMLElement | null
    const ov = document.getElementById('gcOverflow') as HTMLElement | null
    if (ovBtn && ovMenu && ov) {
      ovBtn.addEventListener('click', (e) => {
        e.stopPropagation()
        const open = ovBtn.getAttribute('aria-expanded') === 'true'
        const next = !open
        ovBtn.setAttribute('aria-expanded', String(next))
        ovMenu.hidden = !next
      })
      document.addEventListener('click', (e) => {
        if (!ov.contains(e.target as Node)) {
          ovBtn.setAttribute('aria-expanded', 'false')
          ovMenu.hidden = true
        }
      })
      // Close after clicking a menu item (action still runs via other listeners).
      ovMenu.addEventListener('click', () => {
        ovBtn.setAttribute('aria-expanded', 'false')
        ovMenu.hidden = true
      })
    }
  }

  document.addEventListener('DOMContentLoaded', initGraphControlsChrome)
  document.addEventListener('astro:page-load', initGraphControlsChrome)
</script>

<style>
  /* sr-only utility — visually hidden but accessible to screen readers */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .graph-controls {
    border-bottom: 1px solid var(--ink);
    padding: 0;
    margin-bottom: var(--space-6);
  }

  .controls-row {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    align-items: center;
    padding: var(--space-3) 0;
  }

  .group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* mono eyebrow label */
  .lab {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    user-select: none;
  }

  /* segment button group — borderless cluster with outer 1px frame */
  .btn-group {
    display: flex;
    border: 1px solid var(--ink);
  }

  .seg {
    border: 0;
    background: transparent;
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    padding: 6px 14px;
    color: var(--ink-3);
    cursor: pointer;
    letter-spacing: var(--track-badge);
    text-transform: uppercase;
    border-right: 1px solid var(--ink);
    /* bottom border reserved for active emphasis */
    border-bottom: 3px solid transparent;
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease),
      border-bottom-color var(--dur-fast) var(--ease);
    line-height: 1;
  }

  .seg:last-child {
    border-right: 0;
  }

  /* Active: invert + 3px bottom emphasis */
  .seg--active {
    background: var(--ink);
    color: var(--paper);
    border-bottom-color: var(--ink);
  }

  /* Hover: full invert (not subtle opacity) */
  .seg:hover:not(.seg--active) {
    background: var(--ink);
    color: var(--paper);
  }

  .seg:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }

  /* spacer pushes stats + action buttons to right */
  .spacer {
    flex: 1;
  }

  /* inline stats — mono eyebrow style */
  .stats {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    color: var(--ink-3);
    white-space: nowrap;
  }

  /* depth disclosure button — mono eyebrow wearing a button suit */
  .disclosure {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    background: transparent;
    border: 0;
    padding: 6px 8px;
    cursor: pointer;
    transition: color var(--dur-fast) var(--ease);
  }

  .disclosure:hover {
    color: var(--ink);
  }

  .disclosure[aria-expanded="true"] {
    color: var(--ink);
  }

  .disclosure:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* hidden groups honor the hidden attribute */
  [hidden] { display: none !important; }

  /* overflow menu — one trigger for share + list */
  .overflow {
    position: relative;
  }

  .overflow-trigger {
    font-family: var(--f-mono);
    font-size: var(--fs-sm);
    font-weight: 600;
    padding: 6px 12px;
    border: 1px solid var(--ink);
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    border-radius: var(--r-xs);
    line-height: 1;
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }

  .overflow-trigger:hover,
  .overflow-trigger[aria-expanded="true"] {
    background: var(--ink);
    color: var(--paper);
  }

  .overflow-trigger:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  .overflow-menu {
    position: absolute;
    top: calc(100% + 4px);
    right: 0;
    min-width: 160px;
    background: var(--paper);
    border: 1px solid var(--ink);
    z-index: 20;
    display: flex;
    flex-direction: column;
  }

  .overflow-item {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    text-align: left;
    padding: 10px 14px;
    border: 0;
    border-bottom: 1px solid var(--rule-soft);
    background: var(--paper);
    color: var(--ink);
    cursor: pointer;
    transition:
      background var(--dur-fast) var(--ease),
      color var(--dur-fast) var(--ease);
  }

  .overflow-item:last-child {
    border-bottom: 0;
  }

  .overflow-item:hover,
  .overflow-item[aria-pressed="true"],
  .overflow-item[aria-checked="true"] {
    background: var(--ink);
    color: var(--paper);
  }

  .overflow-item:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }

  /* level caption — mono eyebrow style, below controls row */
  .level-caption {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--space-3);
    padding-bottom: var(--space-2);
  }

  /* ── Mobile 2-row split at ≤780px ───────────────────────────────── */
  @media (max-width: 780px) {
    .controls-row {
      gap: var(--space-3) var(--space-4);
    }

    /* spacer becomes a full-width line break between groups and stats row */
    .controls-row .spacer {
      flex-basis: 100%;
      flex: none;
      height: 0;
      order: 0;
    }

    /* mode + level groups stay on row 1 (order before spacer break) */
    .controls-row .group {
      order: -1;
    }

    /* stats moves to row 2, left-aligned, grows to fill space */
    .controls-row .stats {
      order: 1;
      flex: 1;
      white-space: normal;
    }

    /* action buttons on row 2, right-aligned */
    .controls-row .action-btn {
      order: 2;
    }

    .level-caption {
      margin-top: var(--space-2);
    }
  }
</style>
