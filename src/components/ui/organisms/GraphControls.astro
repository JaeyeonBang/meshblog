---
interface Props {
  mode: 'notes' | 'concepts';
  level: 1 | 2 | 3;
}
const { mode, level } = Astro.props;
---
<div class="graph-controls">
  <div class="group">
    <span class="lab">mode</span>
    <div class="btn-group" role="radiogroup" aria-label="View mode">
      <button
        class:list={[mode === 'notes' && 'active']}
        data-mode="notes"
        role="radio"
        aria-checked={mode === 'notes'}
      >notes</button>
      <button
        class:list={[mode === 'concepts' && 'active']}
        data-mode="concepts"
        role="radio"
        aria-checked={mode === 'concepts'}
      >concepts</button>
    </div>
  </div>
  <div class="group">
    <span class="lab">level</span>
    <div class="btn-group" role="radiogroup" aria-label="Depth level">
      {([1, 2, 3] as const).map((l) => (
        <button
          class:list={[level === l && 'active']}
          data-level={l}
          role="radio"
          aria-checked={level === l}
        >L{l}</button>
      ))}
    </div>
  </div>
  <div class="spacer"></div>
  <button class="btn btn-sm">share link</button>
  <button class="btn btn-sm">list view</button>
</div>

<style>
  .graph-controls {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
    align-items: center;
    padding: 14px 0;
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-6);
  }
  .group {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .lab {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .btn-group {
    display: flex;
    border: 1px solid var(--ink);
  }
  .btn-group button {
    border: 0;
    background: transparent;
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    padding: 6px 14px;
    color: var(--ink-3);
    cursor: pointer;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border-right: 1px solid var(--ink);
    transition: all var(--dur-fast) var(--ease);
  }
  .btn-group button:last-child {
    border-right: 0;
  }
  .btn-group button.active {
    background: var(--ink);
    color: var(--paper);
  }
  .btn-group button:hover:not(.active) {
    background: var(--paper-2);
    color: var(--ink);
  }
  .btn-group button:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }
  .spacer {
    flex: 1;
  }
  .btn {
    font-family: var(--f-sans);
    font-size: var(--fs-sm);
    font-weight: 500;
    padding: 8px 16px;
    border: 1px solid var(--ink);
    cursor: pointer;
    background: var(--paper);
    color: var(--ink);
    border-radius: var(--r-xs);
    transition: all var(--dur-fast) var(--ease);
    display: inline-flex;
    align-items: center;
    gap: 7px;
    letter-spacing: 0.01em;
  }
  .btn:hover {
    background: var(--ink);
    color: var(--paper);
  }
  .btn:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .btn-sm {
    padding: 6px 12px;
    font-size: 12px;
  }
</style>
