---
import { withBase } from '../../../lib/url';
import T from '../atoms/T.astro';
---
<footer class="footer">
  <div class="footer-box">
    <div class="footer-col">
      <div class="brand">meshblog</div>
      <div class="tagline"><T ko="2nd brain · public." en="2nd brain · public." /></div>
    </div>
    <div class="footer-col">
      <div class="ch"><T ko="읽기" en="read" /></div>
      <a href={withBase('/posts')}>latest posts</a>
      <a href={withBase('/atom.xml')}>atom · rss</a>
    </div>
    <div class="footer-col">
      <div class="ch"><T ko="탐색" en="explore" /></div>
      <a href={withBase('/notes')}>notes</a>
      <a href={withBase('/categories')}>categories</a>
      <a href={withBase('/graph')}>graph</a>
      <a href={withBase('/graph?mode=concept')}>concept mesh</a>
    </div>
    <div class="footer-col">
      <div class="ch"><T ko="소개" en="about" /></div>
      <a href={withBase('/about')}>about</a>
      <a href={withBase('/about#colophon')}>colophon</a>
      <a href="https://github.com/JaeyeonBang/meshblog" target="_blank" rel="noopener">github</a>
    </div>
  </div>
  <div class="footer-legal">
    <span>© 2026 meshblog</span>
    <span>built with astro + sqlite</span>
  </div>
</footer>

<style>
  .footer {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) 48px;
  }
  .footer-box {
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding: 60px 0 48px;
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1fr;
    gap: var(--space-8);
  }
  @media (max-width: 780px) {
    .footer-box {
      grid-template-columns: 1fr 1fr;
    }
  }
  .footer-col .ch {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 14px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--rule-soft);
  }
  .footer-col a {
    font-family: var(--f-serif);
    font-size: var(--fs-base);
    color: var(--ink-2);
    padding: 4px 0;
    display: block;
    cursor: pointer;
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }
  .footer-col a:hover {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .footer-col a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }
  .brand {
    font-family: var(--f-disp);
    font-size: 32px;
    font-weight: 600;
    margin-bottom: 12px;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tagline {
    font-family: var(--f-serif);
    font-size: 14px;
    color: var(--ink-3);
    line-height: 1.55;
    font-style: italic;
    max-width: 34ch;
  }
  .footer-legal {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    padding: 18px 0;
    letter-spacing: 0.12em;
    display: flex;
    justify-content: space-between;
  }
</style>
