---
import { withBase } from '../../../lib/url';
import { listPosts, listNotes } from '../../../lib/pages/index';

// Build-time search index — slug + title only. Keeps JSON small, client
// filter O(n) fast, no server trip. SQLite FTS is a v2 upgrade.
type SearchItem = {
  id: string
  kind: 'post' | 'note'
  title: string
  href: string
  meta: string
}

let items: SearchItem[] = []
try {
  const posts = listPosts()
  const notes = listNotes()
  items = [
    ...posts.map((p) => ({
      id: `post-${p.slug}`,
      kind: 'post' as const,
      title: p.title,
      href: withBase(`/posts/${p.slug}`),
      meta: `${Math.max(1, Math.round((p.content?.length ?? 0) / 1000))} min`,
    })),
    ...notes.map((n, i) => ({
      id: `note-${n.slug}`,
      kind: 'note' as const,
      title: n.title,
      href: withBase(`/notes/${n.slug}`),
      meta: `N / ${String(i + 1).padStart(2, '0')}`,
    })),
  ]
} catch {
  // DB unreachable (zero-key preview without fixture) — palette degrades to empty.
  items = []
}

const postCount = items.filter(i => i.kind === 'post').length
const noteCount = items.filter(i => i.kind === 'note').length
---
<div class="cmdk-backdrop" id="cmdk-backdrop" role="dialog" aria-modal="true" aria-label="Search" aria-hidden="true">
  <div class="cmdk" id="cmdk-panel">
    <div class="search-box">
      <span class="ico" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.8">
          <circle cx="7" cy="7" r="4.5"/>
          <path d="M10.3 10.3L13.5 13.5"/>
        </svg>
      </span>
      <input
        type="search"
        id="cmdk-input"
        placeholder="검색…"
        autocomplete="off"
        aria-label="Search"
      />
      <span class="kbd" aria-label="Press Escape to close">esc</span>
    </div>

    <div class="results" id="cmdk-results" role="listbox" aria-label="Search results">
    </div>

    <div class="meta-row" aria-hidden="true">
      <span><span class="c">{postCount}</span> posts</span>
      <span><span class="c">{noteCount}</span> notes</span>
    </div>

    <div class="footer" aria-hidden="true">
      <span><span class="kbd">↑↓</span> navigate</span>
      <span><span class="kbd">↵</span> open</span>
      <span><span class="kbd">esc</span> close</span>
    </div>
  </div>
</div>

{/* Build-time search index — inlined so first-paint search has zero latency. */}
<script
  type="application/json"
  id="cmdk-index"
  set:html={JSON.stringify(items)}
/>

<style>
  .cmdk-backdrop {
    position: fixed;
    inset: 0;
    /* Token-aware scrim: uses ink at low opacity so it reads on both light and dark backgrounds */
    background: color-mix(in srgb, var(--ink) 35%, transparent);
    z-index: 90;
    display: none;
    align-items: flex-start;
    justify-content: center;
    padding-top: 12vh;
  }
  .cmdk-backdrop.open {
    display: flex;
  }
  .cmdk {
    width: min(640px, calc(100vw - 32px));
    background: var(--paper);
    border: 1px solid var(--ink);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    max-height: 76vh;
    box-shadow: var(--shadow-hard);
  }
  .search-box {
    padding: 14px 18px;
    display: flex;
    align-items: center;
    gap: 12px;
    border-bottom: 1px solid var(--ink);
  }
  .ico {
    color: var(--ink);
    display: flex;
    flex-shrink: 0;
  }
  .search-box input {
    font-family: var(--f-disp);
    font-size: var(--fs-xl);
    font-weight: 500;
    border: 0;
    background: transparent;
    outline: none;
    flex: 1;
    color: var(--ink);
    letter-spacing: -0.01em;
    width: 100%;
  }
  .search-box input::placeholder {
    color: var(--ink-4);
    font-weight: 400;
  }
  .search-box .kbd {
    margin-left: auto;
    flex-shrink: 0;
  }
  .results {
    flex: 1;
    overflow-y: auto;
    padding: 0;
    min-height: 120px;
  }
  .cmdk-empty {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-4);
    padding: 36px 18px;
    text-align: center;
  }
  .recent-head {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 10px 18px 6px;
  }
  .group-head {
    font-family: var(--f-mono);
    font-size: 10px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    padding: 14px 18px 6px;
    background: var(--paper-2);
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    display: flex;
    align-items: baseline;
    gap: 8px;
  }
  .group-head .c {
    margin-left: auto;
    color: var(--ink-4);
  }
  .result {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 18px;
    cursor: pointer;
    border-bottom: 1px solid var(--rule-soft);
    transition: background var(--dur-fast) var(--ease);
    text-decoration: none;
    color: inherit;
  }
  .result:last-child {
    border-bottom: 0;
  }
  .result:hover,
  .result.active {
    background: var(--ink);
    color: var(--paper);
  }
  .result:hover .m,
  .result.active .m {
    color: var(--ink-5);
  }
  .result:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: -2px;
  }
  .badge-wrap {
    flex-shrink: 0;
    display: inline-flex;
  }
  /* Runtime-rendered kind badge (scoped styles can't reach dynamic HTML) */
  .results :global(.cmdk-kind) {
    font-family: var(--f-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: var(--track-badge);
    text-transform: uppercase;
    padding: 2px 8px;
    border: 1px solid var(--ink);
    display: inline-block;
    line-height: 1.6;
  }
  .results :global(.cmdk-kind--post) {
    background: var(--ink);
    color: var(--paper);
  }
  .results :global(.cmdk-kind--note) {
    background: var(--paper);
    color: var(--ink);
  }
  .result:hover :global(.cmdk-kind),
  .result.active :global(.cmdk-kind) {
    border-color: var(--paper);
  }
  .t {
    font-family: var(--f-disp);
    font-size: var(--fs-md);
    font-weight: 500;
    flex: 1;
    letter-spacing: -0.005em;
  }
  .m {
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    letter-spacing: 0.04em;
    flex-shrink: 0;
  }
  .meta-row {
    padding: 8px 18px;
    display: flex;
    gap: 16px;
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    border-top: 1px solid var(--rule-soft);
    letter-spacing: 0.04em;
  }
  .meta-row .c {
    color: var(--ink);
    margin-right: 4px;
  }
  .footer {
    padding: 10px 18px;
    display: flex;
    gap: 16px;
    font-family: var(--f-mono);
    font-size: 10px;
    color: var(--ink-3);
    border-top: 1px solid var(--ink);
    background: var(--paper-2);
    letter-spacing: 0.04em;
  }
  .footer span {
    display: inline-flex;
    gap: 5px;
    align-items: center;
  }
  .kbd {
    font-family: var(--f-mono);
    font-size: 10px;
    padding: 2px 6px;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--ink-5);
    letter-spacing: 0.04em;
  }
</style>

<script>
  type SearchItem = {
    id: string
    kind: 'post' | 'note'
    title: string
    href: string
    meta: string
  }

  function loadIndex(): SearchItem[] {
    const el = document.getElementById('cmdk-index')
    if (!el) return []
    try {
      return JSON.parse(el.textContent ?? '[]')
    } catch {
      return []
    }
  }

  function filterItems(items: SearchItem[], q: string): SearchItem[] {
    const needle = q.toLowerCase().trim()
    if (!needle) return []
    return items
      .filter(it => it.title.toLowerCase().includes(needle))
      .slice(0, 20)
  }

  function recentItems(items: SearchItem[]): SearchItem[] {
    return items.slice(0, 5)
  }

  function escapeHtml(s: string): string {
    return s
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  function renderSuggestions(container: HTMLElement, allItems: SearchItem[]) {
    const recent = recentItems(allItems)
    if (recent.length === 0) {
      container.innerHTML = '<div class="cmdk-empty">type to search · 볼트를 검색하세요</div>'
      return
    }
    let html = '<div class="recent-head">recent</div>'
    html += recent.map(r => resultHtml(r)).join('')
    container.innerHTML = html
  }

  function renderResults(container: HTMLElement, results: SearchItem[], query: string) {
    if (results.length === 0) {
      container.innerHTML = `<div class="cmdk-empty">no match · ${escapeHtml(query)} 일치 없음</div>`
      return
    }
    const posts = results.filter(r => r.kind === 'post')
    const notes = results.filter(r => r.kind === 'note')
    let html = ''
    if (posts.length > 0) {
      html += `<div class="group-head"><span>posts</span><span class="c">${posts.length}</span></div>`
      html += posts.map(r => resultHtml(r)).join('')
    }
    if (notes.length > 0) {
      html += `<div class="group-head"><span>notes</span><span class="c">${notes.length}</span></div>`
      html += notes.map(r => resultHtml(r)).join('')
    }
    container.innerHTML = html
  }

  function resultHtml(r: SearchItem): string {
    const badgeClass = r.kind === 'post' ? 'cmdk-kind cmdk-kind--post' : 'cmdk-kind cmdk-kind--note'
    return (
      `<a class="result" href="${escapeHtml(r.href)}" role="option">` +
      `<span class="badge-wrap"><span class="${badgeClass}">${r.kind}</span></span>` +
      `<span class="t">${escapeHtml(r.title)}</span>` +
      `<span class="m">${escapeHtml(r.meta)}</span>` +
      `</a>`
    )
  }

  function initCmdK() {
    const bd = document.getElementById('cmdk-backdrop') as HTMLElement | null;
    const inp = document.getElementById('cmdk-input') as HTMLInputElement | null;
    const results = document.getElementById('cmdk-results') as HTMLElement | null;
    if (!bd || !inp || !results) return;

    const items = loadIndex()
    let activeIdx = -1

    function open() {
      bd!.classList.add('open');
      bd!.setAttribute('aria-hidden', 'false');
      renderSuggestions(results!, items)
      activeIdx = items.slice(0, 5).length > 0 ? 0 : -1
      updateActive()
      setTimeout(() => inp!.focus(), 50);
    }

    function close() {
      bd!.classList.remove('open');
      bd!.setAttribute('aria-hidden', 'true');
      inp!.value = '';
      renderSuggestions(results!, items)
      activeIdx = items.slice(0, 5).length > 0 ? 0 : -1
      updateActive()
    }

    function updateActive() {
      const rows = results!.querySelectorAll<HTMLAnchorElement>('.result')
      rows.forEach((row, i) => row.classList.toggle('active', i === activeIdx))
      if (activeIdx >= 0 && rows[activeIdx]) {
        rows[activeIdx].scrollIntoView({ block: 'nearest' })
      }
    }

    inp.addEventListener('input', () => {
      const q = inp.value
      if (!q.trim()) {
        renderSuggestions(results, items)
        activeIdx = items.slice(0, 5).length > 0 ? 0 : -1
        updateActive()
        return
      }
      const filtered = filterItems(items, q)
      renderResults(results, filtered, q)
      activeIdx = filtered.length > 0 ? 0 : -1
      updateActive()
    })

    inp.addEventListener('keydown', (e) => {
      const rows = results.querySelectorAll<HTMLAnchorElement>('.result')
      if (e.key === 'ArrowDown') {
        e.preventDefault()
        if (rows.length === 0) return
        activeIdx = Math.min(activeIdx + 1, rows.length - 1)
        updateActive()
      } else if (e.key === 'ArrowUp') {
        e.preventDefault()
        if (rows.length === 0) return
        activeIdx = Math.max(activeIdx - 1, 0)
        updateActive()
      } else if (e.key === 'Enter') {
        if (activeIdx >= 0 && rows[activeIdx]) {
          e.preventDefault()
          window.location.href = rows[activeIdx].href
        }
      }
    })

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
        e.preventDefault();
        bd!.classList.contains('open') ? close() : open();
      }
      if (e.key === 'Escape' && bd!.classList.contains('open')) {
        close();
      }
    });

    window.addEventListener('cmdk:open', open);

    bd.addEventListener('click', (e) => {
      if (e.target === bd) close();
    });
  }

  // Run on initial load and after Astro view transitions
  document.addEventListener('DOMContentLoaded', initCmdK);
  document.addEventListener('astro:page-load', initCmdK);
</script>
