---
import Base from '../layouts/Base.astro'
import GraphView from '../components/GraphView'
import { withBase } from '../lib/url'
---

<Base
  title="Graph — meshblog"
  description="Explore the concept graph."
  ogImage="/og/index.png"
>
  <div class="graph-page">
    <h1>Graph</h1>
    <p><em>Click any note node to open that post.</em></p>

    <div class="graph-container">
      <GraphView client:only="react" />
    </div>

    <noscript>
      <p>
        Graph requires JavaScript. See the <a href={withBase('/')}>home page</a> for latest
        posts.
      </p>
    </noscript>
  </div>
</Base>

<style>
  /* ── Graph page layout ─────────────────────────────────────────── */

  .graph-page {
    max-width: 1120px;
    margin-inline: auto;
    padding: var(--meshblog-space-8) var(--meshblog-space-4);
  }

  @media (min-width: 768px) {
    .graph-page {
      padding-inline: var(--meshblog-space-8);
    }
  }

  .graph-page h1 {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-3xl);
    font-weight: 500;
    color: var(--meshblog-color-text-primary);
    margin: 0 0 var(--meshblog-space-3) 0;
    text-align: left;
  }

  .graph-page > p {
    font-family: var(--meshblog-font-serif);
    font-style: italic;
    color: var(--meshblog-color-muted);
    font-size: var(--meshblog-font-size-base);
    line-height: 1.5;
    margin: 0 0 var(--meshblog-space-6) 0;
    text-align: left;
  }

  /* ── Graph canvas container — prevents SVG overflow on narrow viewports ── */

  .graph-container {
    width: 100%;
    overflow: hidden;
  }
</style>
