---
import Base from '../layouts/Base.astro'
import GraphView from '../components/GraphView'
import { withBase } from '../lib/url'
---

<Base
  title="Graph — meshblog"
  description="Explore the concept graph."
  ogImage="/og/index.png"
>
  <div class="graph-page">
    <h1>Graph</h1>
    <p>
      An interactive force-directed graph of notes and concepts. Switch between
      <strong>Notes</strong> and <strong>Concepts</strong> mode, and adjust the
      level to control how many connections are shown. Click a note node to open
      that post.
    </p>

    <div class="graph-container">
      <GraphView client:only="react" />
    </div>

    <noscript>
      <p>
        Graph requires JavaScript. See the <a href={withBase('/')}>home page</a> for latest
        posts.
      </p>
    </noscript>
  </div>
</Base>

<style>
  /* ── Graph page layout ─────────────────────────────────────────── */

  .graph-page {
    max-width: 1120px;
    margin-inline: auto;
    padding: var(--meshblog-space-8) var(--meshblog-space-4);
  }

  @media (min-width: 768px) {
    .graph-page {
      padding-inline: var(--meshblog-space-8);
    }
  }

  .graph-page h1 {
    font-size: var(--meshblog-font-size-3xl);
    font-weight: 700;
    margin: 0 0 var(--meshblog-space-4) 0;
  }

  .graph-page > p {
    color: var(--meshblog-color-text-secondary);
    font-size: var(--meshblog-font-size-base);
    line-height: 1.6;
    margin: 0 0 var(--meshblog-space-6) 0;
    max-width: 65ch;
  }

  /* ── Graph canvas container — prevents SVG overflow on narrow viewports ── */

  .graph-container {
    width: 100%;
    overflow: hidden;
  }
</style>
