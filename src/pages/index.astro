---
import Base from '../layouts/Base.astro'
import QAChips from '../components/QAChips.tsx'
import { listPosts, getHomepageQa } from '../lib/pages/index.ts'
import { withBase } from '../lib/url'

const posts = listPosts().slice(0, 5)
const qa = getHomepageQa(10)
---

<Base
  title="meshblog"
  description="Personal 2nd brain — posts, notes, and an AI-powered knowledge graph."
  ogImage="/og/index.png"
>
  <div class="page-column">

    <!-- Masthead -->
    <section class="masthead" aria-labelledby="masthead-heading">
      <p class="masthead-kicker" aria-hidden="true">AN ONGOING JOURNAL &middot; EST. 2026</p>
      <h1 id="masthead-heading" class="masthead-title">meshblog</h1>
      <p class="masthead-sub">A second brain made public — writing that thinks back.</p>
    </section>

    <!-- Posts index -->
    <section class="posts-index" aria-labelledby="posts-heading">
      <h2 id="posts-heading" class="sr-only">Recent posts</h2>
      {posts.length === 0 ? (
        <p class="posts-empty">No posts yet. Run <code>bun run build-index</code>.</p>
      ) : (
        <ol class="posts-list" aria-label="Recent posts">
          {posts.map((post, i) => (
            <li class="post-row">
              <span class="post-index" aria-hidden="true">
                {String(i + 1).padStart(2, '0')}
              </span>
              <a
                href={withBase(`/posts/${post.slug}`)}
                class="post-title"
              >
                {post.title}
              </a>
              <time
                class="post-date"
                datetime={post.created_at}
              >
                {new Date(post.created_at).toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
            </li>
          ))}
        </ol>
      )}
    </section>

    <!-- Q&A chips -->
    {qa.length > 0 && (
      <section class="qa-section" aria-labelledby="qa-heading">
        <h2 id="qa-heading" class="section-label">RECENT QUESTIONS</h2>
        <div class="chips-wrapper">
          <QAChips qas={qa} scope="global" client:idle />
        </div>
      </section>
    )}

    <!-- Graph invitation -->
    <p class="graph-invite">
      Or explore the mesh — every concept, post, and connection, as a graph.{' '}
      <a href={withBase('/graph')} class="graph-link">Open the graph &rarr;</a>
    </p>

  </div>
</Base>

<style>
  /* ── Page column ────────────────────────────────────────────── */

  .page-column {
    max-width: 800px;
    margin-inline: auto;
    padding: var(--meshblog-space-12) var(--meshblog-space-4) var(--meshblog-space-16);
  }

  @media (min-width: 768px) {
    .page-column {
      padding-inline: var(--meshblog-space-6);
      padding-top: var(--meshblog-space-16);
    }
  }

  /* ── Masthead ───────────────────────────────────────────────── */

  .masthead {
    padding-bottom: var(--meshblog-space-12);
  }

  .masthead-kicker {
    font-family: var(--meshblog-font-sans);
    font-size: var(--meshblog-font-size-xs);
    letter-spacing: 0.15em;
    color: var(--meshblog-color-muted);
    margin: 0 0 var(--meshblog-space-4) 0;
    font-variant-numeric: tabular-nums;
    line-height: 1;
  }

  .masthead-title {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-4xl);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--meshblog-color-text-primary);
    margin: 0 0 var(--meshblog-space-5) 0;
  }

  @media (min-width: 640px) {
    .masthead-title {
      font-size: var(--meshblog-font-size-5xl);
    }
  }

  .masthead-sub {
    font-family: var(--meshblog-font-serif);
    font-style: italic;
    font-size: var(--meshblog-font-size-lg);
    color: var(--meshblog-color-text-secondary);
    margin: 0;
    line-height: 1.45;
  }

  /* ── Posts index ────────────────────────────────────────────── */

  .posts-index {
    padding-bottom: var(--meshblog-space-12);
  }

  .posts-empty {
    color: var(--meshblog-color-muted);
    font-size: var(--meshblog-font-size-base);
  }

  .posts-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-row {
    display: grid;
    grid-template-columns: 2.5rem 1fr auto;
    align-items: baseline;
    column-gap: var(--meshblog-space-4);
    padding: var(--meshblog-space-4) 0;
    border-top: 1px solid var(--meshblog-color-rule);
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--meshblog-color-rule);
  }

  .post-index {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-sm);
    color: var(--meshblog-color-muted);
    font-variant-numeric: oldstyle-nums;
    line-height: 1;
    padding-top: 0.1em;
  }

  .post-title {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-md);
    font-weight: 600;
    color: var(--meshblog-color-text-primary);
    text-decoration: none;
    line-height: 1.35;
    transition: color var(--meshblog-dur-fast) var(--meshblog-ease);
  }

  .post-title:hover {
    color: var(--meshblog-color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--meshblog-color-accent);
  }

  .post-title:focus-visible {
    outline: 2px solid var(--meshblog-color-focus-ring);
    outline-offset: 2px;
    border-radius: var(--meshblog-radius-sm);
  }

  .post-date {
    font-family: var(--meshblog-font-sans);
    font-size: var(--meshblog-font-size-xs);
    color: var(--meshblog-color-muted);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  /* On very small screens, let the date wrap beneath the title */
  @media (max-width: 480px) {
    .post-row {
      grid-template-columns: 2.5rem 1fr;
      grid-template-rows: auto auto;
    }

    .post-date {
      grid-column: 2;
      margin-top: var(--meshblog-space-1);
    }
  }

  /* ── Q&A section ────────────────────────────────────────────── */

  .qa-section {
    padding-bottom: var(--meshblog-space-10);
  }

  .section-label {
    font-family: var(--meshblog-font-sans);
    font-size: var(--meshblog-font-size-xs);
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--meshblog-color-muted);
    margin: 0 0 var(--meshblog-space-4) 0;
  }

  /* On mobile: hide chips beyond 4th via CSS */
  .chips-wrapper :global(.list > li:nth-child(n + 5)) {
    display: none;
  }

  @media (min-width: 768px) {
    .chips-wrapper :global(.list > li:nth-child(n + 5)) {
      display: revert;
    }
    .chips-wrapper :global(.list > li:nth-child(n + 7)) {
      display: none;
    }
  }

  /* ── Graph invitation ───────────────────────────────────────── */

  .graph-invite {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-base);
    color: var(--meshblog-color-text-secondary);
    margin: 0;
    line-height: 1.6;
  }

  .graph-link {
    color: var(--meshblog-color-text-secondary);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--meshblog-color-rule);
    transition: color var(--meshblog-dur-fast) var(--meshblog-ease),
      text-decoration-color var(--meshblog-dur-fast) var(--meshblog-ease);
  }

  .graph-link:hover {
    color: var(--meshblog-color-accent);
    text-decoration-color: var(--meshblog-color-accent);
  }

  .graph-link:focus-visible {
    outline: 2px solid var(--meshblog-color-focus-ring);
    outline-offset: 2px;
    border-radius: var(--meshblog-radius-sm);
  }
</style>
