---
import Base from '../layouts/Base.astro'
import PostCard from '../components/ui/molecules/PostCard.astro'
import NoteRow from '../components/ui/molecules/NoteRow.astro'
import SectionBreak from '../components/ui/molecules/SectionBreak.astro'
import TOC from '../components/ui/molecules/TOC.astro'
import QaCard from '../components/ui/molecules/QaCard.astro'
import MiniMesh from '../components/ui/molecules/MiniMesh.astro'
import Button from '../components/ui/atoms/Button.astro'
import Input from '../components/ui/atoms/Input.astro'
import QAChips from '../components/QAChips.tsx'
import { listPosts, listNotes, getHomepageQa } from '../lib/pages/index.ts'
import { withBase } from '../lib/url'

const posts = listPosts().slice(0, 5)
const notes = listNotes().slice(0, 6)
const qa = getHomepageQa(10)

// Static concept mesh nodes for home sidebar
const meshNodes = [
  { label: 'knowledge', x: 36, y: 30, kind: 'hub' as const },
  { label: 'llm',       x: 70, y: 58, kind: 'hub' as const },
  { label: 'rag',       x: 70, y: 22 },
  { label: 'astro',     x: 22, y: 62 },
  { label: 'sqlite',    x: 48, y: 82 },
  { label: 'faq',       x: 14, y: 24 },
]
const meshEdges = [
  { from: 0, to: 2 },
  { from: 0, to: 1 },
  { from: 1, to: 3 },
  { from: 1, to: 4 },
  { from: 0, to: 5 },
]
---

<Base
  title="meshblog"
  description="Personal 2nd brain — posts, notes, and an AI-powered knowledge graph."
  ogImage="/og/index.png"
  topBarActive="posts"
>
  <div class="home-layout">
    <div class="home-main">
      <!-- Home hero — site-specific content, stays inline -->
      <div class="home-hero">
        <div class="eyebrow">issue nº 012 · 2026 · q2</div>
        <h1>두 번째 뇌를, 남들이 읽을 수 있게 <em>내보내기</em>.</h1>
        <p class="sub">Obsidian vault에서 키우고 정적 사이트로 내보내는 개인 블로그. 글은 서로 참조하고, 개념은 그물처럼 얽힌다.</p>
      </div>

      <div class="feed">
        {posts.map((post, i) => (
          <PostCard
            kind="post"
            number={String(i + 1).padStart(2, '0')}
            href={withBase(`/posts/${post.slug}`)}
            title={post.title}
            excerpt={post.content.replace(/[#*`_~\[\]]/g, '').slice(0, 120).trimEnd()}
            date={new Date(post.created_at).toLocaleDateString('ko-KR', { year: 'numeric', month: '2-digit', day: '2-digit' })}
            tags={post.tags ?? []}
          />
        ))}

        <SectionBreak label="notes · atomic" count={`${notes.length} entries`} />

        {notes.map((note, i) => (
          <NoteRow
            number={`N / ${String(i + 1).padStart(2, '0')}`}
            title={note.title}
            meta="2 min"
            href={withBase(`/notes/${note.slug}`)}
          />
        ))}

        <div class="feed-cta">
          <Button href={withBase('/notes')}>notes 전체 보기 →</Button>
        </div>
      </div>
    </div>

    <aside class="home-side">
      <TOC label="ask the vault">
        <Input placeholder="e.g. RAG란?" />
        {qa.length > 0 ? (
          <QAChips qas={qa} scope="global" client:idle />
        ) : (
          qa.map((q) => (
            <QaCard question={q.question} answer={q.answer ?? undefined} />
          ))
        )}
      </TOC>

      <TOC label="concept mesh">
        <MiniMesh nodes={meshNodes} edges={meshEdges} size="md" />
        <div class="mesh-cta">
          <Button href={withBase('/graph')}>전체 그래프 →</Button>
        </div>
      </TOC>

      <TOC label="feed">
        <div class="feed-links">
          <a href={withBase('/atom.xml')}>→ atom · rss</a>
          <a href="https://github.com/jaeyeonbang">→ github</a>
        </div>
      </TOC>
    </aside>
  </div>
</Base>

<style>
  /* ── Home layout ───────────────────────────────────────────── */
  .home-layout {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-24);
    display: grid;
    grid-template-columns: 1fr var(--w-side);
    gap: 0;
  }

  @media (max-width: 980px) {
    .home-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ── Home main column ──────────────────────────────────────── */
  .home-main {
    padding-right: var(--space-12);
    border-right: 1px solid var(--ink);
    padding-bottom: var(--space-16);
  }

  @media (max-width: 980px) {
    .home-main {
      padding-right: 0;
      border-right: 0;
    }
  }

  /* ── Home hero ─────────────────────────────────────────────── */
  .home-hero {
    padding: var(--space-12) 0 var(--space-10);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-12);
  }

  .home-hero .eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .home-hero .eyebrow::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ink);
  }

  .home-hero h1 {
    font-family: var(--f-disp);
    font-weight: 500;
    font-size: var(--fs-hero);
    line-height: .96;
    margin: 0 0 var(--space-6);
    letter-spacing: -.025em;
    max-width: 14ch;
    font-variation-settings: "opsz" 144;
  }

  .home-hero h1 em {
    font-style: italic;
    font-weight: 400;
    font-family: var(--f-disp);
  }

  .home-hero .sub {
    font-family: var(--f-serif);
    font-size: var(--fs-xl);
    color: var(--ink-2);
    line-height: 1.5;
    max-width: 52ch;
    font-weight: 400;
    margin: 0;
  }

  /* ── Feed ──────────────────────────────────────────────────── */
  .feed {
    display: flex;
    flex-direction: column;
  }

  .feed-cta {
    margin-top: var(--space-8);
    align-self: flex-start;
  }

  /* ── Home side ─────────────────────────────────────────────── */
  .home-side {
    padding: var(--space-10) 0 0 var(--space-10);
  }

  @media (max-width: 980px) {
    .home-side {
      padding: 0;
      border-top: 1px solid var(--ink);
      margin-top: var(--space-10);
      padding-top: var(--space-10);
    }
  }

  .mesh-cta {
    margin-top: var(--space-4);
    width: 100%;
  }

  .feed-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .feed-links a {
    font-family: var(--f-serif);
    font-size: var(--fs-sm);
    color: var(--ink-2);
    padding: 4px 0;
    display: block;
    transition: color var(--dur-fast) var(--ease);
  }

  .feed-links a:hover {
    color: var(--ink);
  }
</style>
