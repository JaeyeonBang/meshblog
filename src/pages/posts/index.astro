---
import Base from '../../layouts/Base.astro'
import PostCard from '../../components/ui/molecules/PostCard.astro'
import PostsIndexSidebar from '../../components/ui/molecules/PostsIndexSidebar.astro'
import { listPosts } from '../../lib/pages/index.ts'
import type { PostRow } from '../../lib/pages/index.ts'
import { withBase } from '../../lib/url'
import { plainExcerpt } from '../../lib/markdown/plain-excerpt'

const posts: PostRow[] = listPosts()
const count = posts.length

const now = Date.now()
const NEW_THRESHOLD_MS = 14 * 24 * 60 * 60 * 1000
const ONE_MONTH = 30 * 24 * 60 * 60 * 1000

function getPostBadge(post: PostRow): 'new' | 'updated' | null {
  const created = new Date(post.created_at).getTime()
  const updated = new Date(post.updated_at).getTime()
  if (now - created <= NEW_THRESHOLD_MS) return 'new'
  if (now - updated <= ONE_MONTH) return 'updated'
  return null
}

// Stats eyebrow: most recent updated_at as YYYY-MM
const latestDate = posts.length > 0
  ? (() => {
      const d = new Date(posts[0].updated_at)
      return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
    })()
  : null
---

<Base
  title="posts · meshblog"
  description="All curated posts from the meshblog vault — writing on software, systems, and ideas."
  topBarActive="posts"
>
  <div class="index-layout-outer">
    <header class="index-header">
      <p class="eyebrow">curated{latestDate ? ` · ${latestDate}` : ''}</p>
      <h1>posts</h1>
      <p class="stats">
        <span data-stats-count>{count}</span>
        <span> {count === 1 ? 'entry' : 'entries'}</span>
      </p>
    </header>

    <!-- Active-tag chip — populated client-side from ?tag= search param -->
    <div class="filter-bar" data-filter-bar hidden>
      <span class="filter-label">filtered by</span>
      <span class="filter-tag" data-filter-tag></span>
      <a class="filter-clear" href={withBase('/posts')} data-filter-clear>clear ×</a>
    </div>

    <div class="index-layout">
      <main class="index-main">
        <!-- h2 bridges h1 → h2 inside PostCard (no skip) and provides visible section label -->
        <h2 class="section-label">all posts</h2>
        <div data-posts-list>
          {posts.length > 0 ? posts.map((post, i) => (
            <PostCard
              kind="post"
              number={String(i + 1).padStart(2, '0')}
              href={withBase(`/posts/${post.slug}`)}
              title={post.title}
              excerpt={plainExcerpt(post.content, 120)}
              date={new Date(post.created_at).toLocaleDateString('ko-KR', {
                year: 'numeric',
                month: '2-digit',
                day: '2-digit',
              })}
              tags={post.tags ?? []}
              image={withBase(`/og/posts/${post.slug}.svg`)}
              featured={i === 0}
              badge={getPostBadge(post)}
              tagsAsLinks={true}
            />
          )) : (
            <p class="empty">아직 올라온 글이 없습니다 · still drafting.</p>
          )}
        </div>
        <p class="empty" data-no-results hidden>이 태그가 달린 글이 없습니다 · no posts with this tag.</p>
      </main>

      <aside class="reader-aside">
        <PostsIndexSidebar posts={posts} />
      </aside>
    </div>
  </div>
</Base>

<script>
  (function () {
    const params = new URLSearchParams(window.location.search)
    const activeTag = params.get('tag')

    const bar = document.querySelector<HTMLElement>('[data-filter-bar]')
    const tagEl = document.querySelector<HTMLElement>('[data-filter-tag]')
    const cards = document.querySelectorAll<HTMLElement>('[data-post-card]')
    const noResults = document.querySelector<HTMLElement>('[data-no-results]')
    const countEl = document.querySelector<HTMLElement>('[data-stats-count]')
    const totalCount = cards.length

    function applyFilter(tag: string | null) {
      let visible = 0
      cards.forEach((card) => {
        // Tags joined with U+001F (unit separator) so a literal "|" in a tag
        // can't mis-split. Empty data-tags (no tags) → empty array.
        const tags = (card.getAttribute('data-tags') || '').split('\u001F').filter(Boolean)
        const match = !tag || tags.includes(tag)
        card.hidden = !match
        if (match) {
          visible++
          // First *visible* card becomes the leader (large h2 + extra padding),
          // not just the SSR-first card. After filtering, the new leader takes
          // over so the list never looks decapitated.
          card.classList.toggle('featured', visible === 1)
        }
      })
      if (countEl) countEl.textContent = String(visible)
      if (noResults) noResults.hidden = visible !== 0
    }

    if (activeTag) {
      if (bar && tagEl) {
        tagEl.textContent = `#${activeTag}`
        bar.hidden = false
      }
      applyFilter(activeTag)
    }

    document.querySelectorAll<HTMLAnchorElement>('a[data-tag-filter]').forEach((a) => {
      a.addEventListener('click', (e) => {
        e.preventDefault()
        const tag = a.getAttribute('data-tag-filter')
        if (!tag) return
        const url = new URL(window.location.href)
        url.searchParams.set('tag', tag)
        history.pushState(null, '', url.toString())
        if (bar && tagEl) {
          tagEl.textContent = `#${tag}`
          bar.hidden = false
        }
        applyFilter(tag)
        window.scrollTo({ top: 0, behavior: 'smooth' })
      })
    })

    const clearEl = document.querySelector<HTMLAnchorElement>('[data-filter-clear]')
    if (clearEl) {
      clearEl.addEventListener('click', (e) => {
        e.preventDefault()
        const url = new URL(window.location.href)
        url.searchParams.delete('tag')
        history.pushState(null, '', url.pathname + url.hash)
        if (bar) bar.hidden = true
        applyFilter(null)
        if (countEl) countEl.textContent = String(totalCount)
      })
    }

    window.addEventListener('popstate', () => {
      const t = new URLSearchParams(window.location.search).get('tag')
      if (t) {
        if (bar && tagEl) {
          tagEl.textContent = `#${t}`
          bar.hidden = false
        }
        applyFilter(t)
      } else {
        if (bar) bar.hidden = true
        applyFilter(null)
      }
    })
  })()
</script>

<style>
  /* ── Outer wrapper (page-level constraints) ─────────────────── */
  .index-layout-outer {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-24);
  }

  /* ── Page header (full-width above the grid) ─────────────────── */
  .index-header {
    padding: var(--space-12) 0 var(--space-10);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-12);
  }

  .eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .eyebrow::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ink);
  }

  h1 {
    font-family: var(--f-disp);
    font-weight: 500;
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.0;
    margin: 0 0 var(--space-3);
    letter-spacing: -0.025em;
    font-variation-settings: "opsz" 144;
  }

  .stats {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    margin: 0;
  }

  /* ── Filter bar (active tag chip) ────────────────────────── */
  .filter-bar {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--ink);
    margin-bottom: var(--space-8);
    max-width: var(--w-prose);
  }
  .filter-label {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
  }
  .filter-tag {
    font-family: var(--f-mono);
    font-size: var(--fs-sm);
    font-weight: 700;
    color: var(--ink);
  }
  .filter-clear {
    margin-left: auto;
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    text-decoration: none;
    border: 1px solid var(--ink-5);
    padding: 4px 8px;
    cursor: pointer;
    transition: all var(--dur-fast) var(--ease);
  }
  .filter-clear:hover {
    background: var(--ink);
    color: var(--paper);
    border-color: var(--ink);
  }

  /* ── 2-column grid (main list + right aside) ─────────────────── */
  /*
   * Width math: page 1280, padding 2×32=64 → content 1216
   * Aside 240 (--w-reader-side), gap 48 (--space-12)
   * Main column: 1216 - 240 - 48 = 928. Cards cap at --w-post-list (770px).
   * Intentional left-lean within the 928px column — editorial asymmetry.
   */
  .index-layout {
    display: grid;
    grid-template-columns: 1fr var(--w-reader-side);
    gap: var(--space-12);
    align-items: start;
  }

  /* ── Section label (h2 visible bridge) ────────────────────── */
  .section-label {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 400;
    margin: 0 0 var(--space-4);
  }

  /* ── Main post list ─────────────────────────────────────────── */
  /* --w-post-list (design.md → tokens.css). Wider than --w-prose
     because PostCards carry a 160px thumb + 28px gap on the left.
     Editorial asymmetry preserved on the 1280px page. */
  .index-main {
    display: flex;
    flex-direction: column;
    max-width: var(--w-post-list);
  }

  /* ── Right aside ─────────────────────────────────────────────── */
  .reader-aside {
    padding-top: var(--space-5);
    align-self: start;
  }

  .empty {
    font-family: var(--f-serif);
    font-size: var(--fs-md);
    font-style: italic;
    color: var(--ink-3);
    padding: var(--space-6) 0;
  }

  /* ── Tablet: collapse to single column (980px) ───────────────── */
  /*
   * Aside gets order:1 so the post list stays first on mobile.
   * (This is the INDEX page — posts first is the right UX.)
   * Contrast with reader pages where order:-1 puts aside above article.
   */
  @media (max-width: 980px) {
    .index-layout {
      grid-template-columns: 1fr;
    }

    .reader-aside {
      order: 1;
    }
  }

  /* ── Phone: hide aside entirely (≤779px) ─────────────────────── */
  /* Post list IS the page on phones. Categories reachable via TopBar/CmdK. */
  @media (max-width: 779px) {
    .reader-aside {
      display: none;
    }
  }
</style>
