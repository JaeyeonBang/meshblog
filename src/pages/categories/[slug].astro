---
import Base from '../../layouts/Base.astro'
import NoteRow from '../../components/ui/molecules/NoteRow.astro'
import PostCard from '../../components/ui/molecules/PostCard.astro'
import PostsIndexSidebar from '../../components/ui/molecules/PostsIndexSidebar.astro'
import T from '../../components/ui/atoms/T.astro'
import {
  listCategories,
  listNotesByCategory,
  listPostsByCategory,
  listPosts,
} from '../../lib/pages/index.ts'
import type { CategoryRow } from '../../lib/pages/index.ts'
import { withBase } from '../../lib/url'
import { plainExcerpt } from '../../lib/markdown/plain-excerpt'
import { formatCategoryName } from '../../lib/categories/display-name'

export function getStaticPaths() {
  const categories: CategoryRow[] = listCategories()
  return categories.map((cat) => ({
    params: { slug: cat.slug },
    props: { cat },
  }))
}

interface Props {
  cat: CategoryRow
}

const { cat } = Astro.props
const notes = listNotesByCategory(cat.slug)
const posts = listPostsByCategory(cat.slug)
const hasContent = notes.length > 0 || posts.length > 0
const catName = formatCategoryName(cat.slug, cat.name)

// Sidebar mirrors /posts so the IA shell stays identical: same categories list
// (with this slug active), same site-wide tag cloud, same related-graph teaser.
const allPosts = listPosts()
---

<Base
  title={`${catName} · categories · meshblog`}
  description={`Notes and posts in the ${catName} category on meshblog.`}
>
  <div class="index-layout-outer">
    <header class="index-header">
      <p class="eyebrow">categories · {catName}</p>
      <h1>{catName}</h1>
      <p class="stats">
        <span>{cat.noteCount} {cat.noteCount === 1 ? 'note' : 'notes'}</span>
        <span> · </span>
        <span>{cat.postCount} {cat.postCount === 1 ? 'post' : 'posts'}</span>
      </p>
    </header>

    <div class="index-layout">
      <main class="index-main">
        {!hasContent && (
          <p class="empty"><T ko="이 카테고리에 항목이 없습니다." en="no items in this category yet." /></p>
        )}

        {notes.length > 0 && (
          <section class="cat-section">
            <h2 class="section-label"><T ko="노트" en="notes" /></h2>
            {notes.map((note, i) => (
              <NoteRow
                number={`N / ${String(i + 1).padStart(2, '0')}`}
                title={note.title}
                meta={(() => {
                  const d = new Date(note.updated_at)
                  return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}`
                })()}
                href={withBase(`/notes/${note.slug}`)}
              />
            ))}
          </section>
        )}

        {posts.length > 0 && (
          <section class="cat-section">
            <h2 class="section-label"><T ko="글" en="posts" /></h2>
            {posts.map((post, i) => (
              <PostCard
                kind="post"
                number={String(i + 1).padStart(2, '0')}
                href={withBase(`/posts/${post.slug}`)}
                title={post.title}
                excerpt={plainExcerpt(post.content, 120)}
                date={new Date(post.created_at).toLocaleDateString('ko-KR', {
                  year: 'numeric',
                  month: '2-digit',
                  day: '2-digit',
                })}
                tags={post.tags ?? []}
                tagsAsLinks={true}
              />
            ))}
          </section>
        )}
      </main>

      <aside class="reader-aside">
        <PostsIndexSidebar posts={allPosts} activeCategory={cat.slug} />
      </aside>
    </div>
  </div>
</Base>

<style>
  /* Mirrors /posts/index.astro shell so the IA stays identical: header above,
     2-column main + aside grid, same collapse rules. */
  .index-layout-outer {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-24);
  }

  /* ── Page header ────────────────────────────────────────────── */
  .index-header {
    padding: var(--space-12) 0 var(--space-10);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-12);
  }

  .eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--space-5);
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .eyebrow::before {
    content: "";
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--ink);
  }

  h1 {
    font-family: var(--f-disp);
    font-weight: 500;
    font-size: clamp(44px, 6vw, 72px);
    line-height: 1.0;
    margin: 0 0 var(--space-3);
    letter-spacing: -0.025em;
    font-variation-settings: "opsz" 144;
  }

  .stats {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    margin: 0;
  }

  /* ── 2-column grid (matches /posts) ─────────────────────────── */
  .index-layout {
    display: grid;
    grid-template-columns: 1fr var(--w-reader-side);
    gap: var(--space-12);
    align-items: start;
  }

  /* ── Section label (h2 bridge) ────────────────────────────── */
  .section-label {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 400;
    margin: 0 0 var(--space-4);
  }

  /* ── Main column ───────────────────────────────────────────── */
  .index-main {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
    max-width: var(--w-post-list);
  }

  .cat-section {
    display: flex;
    flex-direction: column;
  }

  .reader-aside {
    padding-top: var(--space-5);
    align-self: start;
  }

  .empty {
    font-family: var(--f-serif);
    font-size: var(--fs-md);
    font-style: italic;
    color: var(--ink-3);
    padding: var(--space-6) 0;
  }

  /* ── Tablet: collapse to single column (980px) ─────────────── */
  @media (max-width: 980px) {
    .index-layout {
      grid-template-columns: 1fr;
    }

    .reader-aside {
      order: 1;
    }
  }

  /* ── Phone: hide aside entirely (≤779px) ───────────────────── */
  @media (max-width: 779px) {
    .reader-aside {
      display: none;
    }
  }
</style>
