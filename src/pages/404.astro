---
import Base from '../layouts/Base.astro'
import { withBase } from '../lib/url'
---

<Base
  title="404 — not found"
  description="This page does not exist. Head back home or search the knowledge graph."
>
  <section class="not-found">
    <p class="error-code" aria-hidden="true">404</p>
    <h1>Page not found</h1>
    <p class="message">
      The page you requested does not exist. It may have been moved, deleted,
      or never published.
    </p>

    <nav class="actions" aria-label="Recovery options">
      <a href={withBase('/')} class="action-link">→ Back to home</a>
      <a href={withBase('/#ask-heading')} class="action-link">→ Search the knowledge graph</a>
    </nav>
  </section>
</Base>

<style>
  .not-found {
    max-width: 38ch;
    margin-inline: auto;
    padding-block-start: var(--meshblog-space-32);
    padding-block-end: var(--meshblog-space-16);
    padding-inline: var(--meshblog-space-4);
    text-align: center;
  }

  @media (max-width: 640px) {
    .not-found {
      padding-block-start: var(--meshblog-space-16);
    }
  }

  .error-code {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-5xl);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--meshblog-color-muted);
    margin: 0 0 var(--meshblog-space-4) 0;
    user-select: none;
  }

  .not-found h1 {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-2xl);
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 var(--meshblog-space-4) 0;
    color: var(--meshblog-color-text-primary);
  }

  .message {
    font-family: var(--meshblog-font-serif);
    font-style: italic;
    font-size: var(--meshblog-font-size-base);
    color: var(--meshblog-color-text-secondary);
    line-height: 1.6;
    margin: 0 0 var(--meshblog-space-10) 0;
  }

  /* ── Actions ──────────────────────────────────────────────── */

  .actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--meshblog-space-3);
  }

  .action-link {
    font-family: var(--meshblog-font-serif);
    font-size: var(--meshblog-font-size-base);
    color: var(--meshblog-color-text-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
    transition: color var(--meshblog-dur-fast) var(--meshblog-ease);
  }

  .action-link:hover,
  .action-link:focus-visible {
    color: var(--meshblog-color-accent);
  }

  .action-link:focus-visible {
    outline: 2px solid var(--meshblog-color-focus-ring);
    outline-offset: 3px;
    border-radius: 2px;
  }
</style>
