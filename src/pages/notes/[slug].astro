---
import Base from '../../layouts/Base.astro'
import QAChips from '../../components/QAChips.tsx'
import Breadcrumbs from '../../components/ui/molecules/Breadcrumbs.astro'
import KindBadge from '../../components/ui/atoms/KindBadge.astro'
import Tag from '../../components/ui/atoms/Tag.astro'
import PageQa from '../../components/ui/molecules/PageQa.astro'
import RelatedGrid from '../../components/ui/molecules/RelatedGrid.astro'
import Pager from '../../components/ui/molecules/Pager.astro'
import TOC from '../../components/ui/molecules/TOC.astro'
import PostMeshGraph from '../../components/PostMeshGraph'
import { renderMarkdownToHtml } from '../../lib/markdown/render'
import { buildNoteResolver } from '../../lib/markdown/wikilink-resolver'
import {
  listNotes,
  listAllNotesUnfiltered,
  listAllLinkable,
  listAllNoteSlugs,
  getQaForNote,
  getRelatedNotes,
  getBacklinksForNote,
  openReadonlyDb,
} from '../../lib/pages/index.ts'
import type { NoteRow, QaCard, RelatedNote, Backlink } from '../../lib/pages/index.ts'
import { loadMeshblogConfig, getL3NoteSlugs } from '../../lib/config'
import PrivatePlaceholder from '../../components/ui/molecules/PrivatePlaceholder.astro'
import { readFileSync } from 'node:fs'
import { fileURLToPath } from 'node:url'
import { join } from 'node:path'
import { estimateReadingMinutes } from '../../lib/reading-time'
import { getReadingStats } from '../../lib/word-count'
import { withBase } from '../../lib/url'
import { injectLedeClass } from '../../lib/lede'
import { stripLeadingH1 } from '../../lib/markdown/strip-title'
import { extractToc } from '../../lib/markdown/extract-toc'
import { plainExcerpt } from '../../lib/markdown/plain-excerpt'
import { getNoteMeshNodes, getNoteMeshLinks } from '../../lib/mesh-data'
import '../../styles/article.css'

export function getStaticPaths() {
  const { l3Visibility } = loadMeshblogConfig()
  const allSlugs = listAllNoteSlugs()
  // Use unfiltered list so keyword-only mode still has NoteRow props for L3
  // slugs (needed to render the PrivatePlaceholder with the correct title).
  // listNotes() strips L3 items in keyword-only/hidden, causing missing props.
  const allNotesFull = listAllNotesUnfiltered()

  // In hidden mode, exclude L3 slugs from getStaticPaths so Astro never builds the page.
  if (l3Visibility === 'hidden') {
    const db = openReadonlyDb()
    const l3 = db ? (() => { try { return getL3NoteSlugs(db) } finally { db.close() } })() : new Set<string>()
    const visible = allSlugs.filter((s) => !l3.has(s.slug))
    const noteMap = new Map(allNotesFull.map((n) => [n.slug, n]))
    return visible.map((s) => ({
      params: { slug: s.slug },
      props: { note: noteMap.get(s.slug) ?? allNotesFull.find((n) => n.slug === s.slug) },
    })).filter((entry) => entry.props.note !== undefined)
  }

  // full / keyword-only: all slugs are buildable (keyword-only renders placeholder).
  // We need full NoteRow for props — join on slug.
  const noteMap = new Map(allNotesFull.map((n) => [n.slug, n]))
  return allSlugs.map((s) => ({
    params: { slug: s.slug },
    props: { note: noteMap.get(s.slug) ?? allNotesFull.find((n) => n.slug === s.slug) },
  })).filter((entry) => entry.props.note !== undefined)
}

const { note } = Astro.props as { note: NoteRow }

// Fetch note-tier QA cards
const noteQa: QaCard[] = getQaForNote(note.id)

// Fetch concept-tier QA cards via inline SQL
let conceptQa: QaCard[] = []
const db = openReadonlyDb()
if (db) {
  try {
    const rows = db
      .prepare(
        `SELECT q.id, q.tier, q.question, q.answer, q.note_id, q.concept_id
         FROM qa_cards q
         JOIN concept_entities ce ON ce.concept_id = q.concept_id
         JOIN note_entities ne ON ne.entity_id = ce.entity_id
         WHERE ne.note_id = ? AND q.tier = 'concept'
         GROUP BY q.id`
      )
      .all(note.id) as any[]
    conceptQa = rows.map((row) => ({
      id: row.id,
      tier: row.tier as 'concept',
      question: row.question,
      answer: row.answer,
      lang: row.lang ?? 'en',
      scope_id: row.concept_id ?? null,
    }))
  } finally {
    db.close()
  }
}

const allQa: QaCard[] = [...noteQa, ...conceptQa]

// Fetch related notes
const related: RelatedNote[] = getRelatedNotes(note.id, 4)

// Fetch backlinks (inbound wikilinks to this note)
const backlinks: Backlink[] = getBacklinksForNote(note.id, 10)

// Read manifest for resolving hrefs
type ManifestEntry = { id: string; href: string; title: string; folder: string }
type Manifest = Record<string, ManifestEntry>

let manifest: Manifest = {}
try {
  const manifestPath = join(
    fileURLToPath(new URL('../../../public/notes-manifest.json', import.meta.url))
  )
  manifest = JSON.parse(readFileSync(manifestPath, 'utf-8')) as Manifest
} catch {
  // manifest not found — hrefs will fall back to /notes/<slug>/
}

function resolveHref(id: string, slug: string): string {
  const entry = manifest[id]
  return withBase(entry?.href ?? `/notes/${slug}/`)
}

// --- Metadata ---
const readingMinutes = estimateReadingMinutes(note.content)
const { words: wordCount } = getReadingStats(note.content)
const updatedDate = new Date(note.updated_at)
const updatedYYYYMM = `${updatedDate.getFullYear()}-${String(updatedDate.getMonth() + 1).padStart(2, '0')}`
const excerpt = plainExcerpt(note.content, 160)
const wikilinkResolver = buildNoteResolver(listAllLinkable())
const contentHtml = await renderMarkdownToHtml(stripLeadingH1(note.content), {
  resolver: wikilinkResolver,
  hrefFor: (slug) => withBase(`/notes/${slug}`),
})

const ledeHtml = injectLedeClass(contentHtml)

// Bilingual body: render EN companion if present
let ledeHtmlEn: string | null = null
if (note.has_en && note.body_en) {
  const contentHtmlEn = await renderMarkdownToHtml(stripLeadingH1(note.body_en), {
    resolver: wikilinkResolver,
    hrefFor: (slug) => withBase(`/notes/${slug}`),
  })
  ledeHtmlEn = injectLedeClass(contentHtmlEn)
}

// All notes for pager
const allNotes = listNotes()
const currentIndex = allNotes.findIndex((n) => n.slug === note.slug)
const prevNote = currentIndex > 0 ? allNotes[currentIndex - 1] : undefined
const nextNote = currentIndex < allNotes.length - 1 ? allNotes[currentIndex + 1] : undefined

// Related grid items
const relatedItems = related.map((r, i) => ({
  kind: 'note' as const,
  number: `N / ${String(i + 1).padStart(2, '0')}`,
  title: r.title,
  meta: '',
  href: resolveHref(r.id, r.slug),
}))

// TOC items from the rendered article HTML (H2/H3 with ids from rehype-slug).
const tocItems = extractToc(contentHtml).map((e) => ({
  label: e.label,
  level: e.level === 2 ? 1 as const : 2 as const,
  href: `#${e.id}`,
}))

// L3 visibility check
const { l3Visibility } = loadMeshblogConfig()
const _l3Db = openReadonlyDb()
const _l3Set = _l3Db ? (() => { try { return getL3NoteSlugs(_l3Db) } finally { _l3Db.close() } })() : new Set<string>()
const isPrivate = l3Visibility === 'keyword-only' && _l3Set.has(note.slug)

// Per-note subgraph: center = this note, neighbors = up to 8 inbound/outbound links.
// Returns just [center] for orphan notes — PostMeshGraph is hidden in that case via length>1 guard.
const meshNodes = getNoteMeshNodes({
  noteId: note.id,
  noteTitle: note.title,
  withBase,
})

// Inter-neighbor edges for the mini graph. Slugs derived from each neighbor's href.
const neighborSlugs = meshNodes.slice(1)
  .map((n) => n.href?.split('/').pop())
  .filter((s): s is string => !!s)
const meshLinks = getNoteMeshLinks(neighborSlugs)
---

<Base
  title={`${note.title} · meshblog`}
  description={excerpt}
  ogImage={`/og/notes/${note.slug}.png`}
  topBarActive="notes"
>
  {isPrivate && <meta name="robots" content="noindex" slot="head" />}
  <div class="reader-layout">
    <article class="reader-article fade-up">
      <Breadcrumbs
        items={[
          { label: 'notes', href: withBase('/notes') },
          { label: note.title },
        ]}
      />

      <header class="article-header">
        <p class="eyebrow">updated {updatedYYYYMM} · {readingMinutes} min read</p>
        <div class="kind-row">
          <KindBadge kind="note" number={`N / ${String(currentIndex + 1).padStart(2, '0')}`} />
          <span class="meta reader-meta">{readingMinutes} min · updated {updatedYYYYMM} · {wordCount} words</span>
        </div>
        <h1>{note.title}</h1>
        {note.tags && note.tags.length > 0 && (
          <div class="tags">
            {note.tags.map((tag: string) => (
              <Tag>{tag}</Tag>
            ))}
          </div>
        )}
      </header>

      {/* EN-mode lang notice: shown only when no EN companion exists */}
      {!note.has_en && (
        <p class="lang-notice">This note is published in Korean. Toggle 한·영 in the top bar.</p>
      )}

      {isPrivate
        ? <PrivatePlaceholder title={note.title} />
        : (
          <>
            <!-- Note variant: no HeroFigure, prose width 52ch -->
            <div class="t-ko prose note-prose" lang="ko">
              <div set:html={ledeHtml} />
            </div>
            {note.has_en && ledeHtmlEn && (
              <div class="t-en prose note-prose" lang="en">
                <div set:html={ledeHtmlEn} />
              </div>
            )}

            {allQa.length > 0 && (
              <div class="page-qa-wrapper">
                <PageQa
                  scope="note"
                  items={allQa.map((q) => ({ question: q.question, answer: q.answer ?? undefined }))}
                />
                <QAChips qas={allQa} scope="page" client:visible />
              </div>
            )}

            {relatedItems.length > 0 && (
              <RelatedGrid items={relatedItems} />
            )}
          </>
        )
      }

      {!isPrivate && (
        <Pager
          prev={prevNote ? {
            number: `N / ${String(currentIndex).padStart(2, '0')}`,
            title: prevNote.title,
            href: withBase(`/notes/${prevNote.slug}`),
          } : undefined}
          next={nextNote ? {
            number: `N / ${String(currentIndex + 2).padStart(2, '0')}`,
            title: nextNote.title,
            href: withBase(`/notes/${nextNote.slug}`),
          } : undefined}
        />
      )}
    </article>

    <aside class="reader-aside">
      {meshNodes.length > 1 && (
        <section aria-label="related mesh" class="related-mesh-section">
          <h3 class="mono-eyebrow">related</h3>
          <PostMeshGraph nodes={meshNodes} links={meshLinks} client:visible />
          <a class="mesh-cta" href={withBase('/graph')}>전체 그래프 →</a>
        </section>
      )}
      {!isPrivate && tocItems.length > 0 && (
        <TOC label="contents" items={tocItems} />
      )}
      {backlinks.length > 0 && (
        <section aria-label="backlinks" class="backlinks-section">
          <h3 class="mono-eyebrow">referenced by · {backlinks.length}</h3>
          <ul>
            {backlinks.map((b) => (
              <li><a href={withBase(`/notes/${b.source_slug}`)}>{b.alias || b.source_title}</a></li>
            ))}
          </ul>
        </section>
      )}
      <TOC label="concepts">
        {note.tags && note.tags.map((tag: string) => (
          <Tag>{tag}</Tag>
        ))}
      </TOC>
    </aside>
  </div>
</Base>

<!-- TOC scroll-spy: watches headings in .prose, toggles .active on TOC links -->
<script>
  (function () {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('.reader-aside a[href^="#"]')
    if (!tocLinks.length) return

    const headingIds = Array.from(tocLinks)
      .map((a) => {
        const id = a.getAttribute('href')?.slice(1)
        return id ? document.getElementById(id) : null
      })
      .filter((el): el is HTMLElement => el !== null)

    if (!headingIds.length) return

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const id = entry.target.id
          const link = document.querySelector<HTMLAnchorElement>(`.reader-aside a[href="#${id}"]`)
          if (link) {
            if (entry.isIntersecting) {
              link.classList.add('active')
            } else {
              link.classList.remove('active')
            }
          }
        })
      },
      { rootMargin: '0px 0px -60% 0px', threshold: 0 }
    )

    headingIds.forEach((el) => observer.observe(el))
  })()
</script>

<!-- Hide broken inline images in .prose (vault attachments not yet wired
     to the build pipeline; pre-existing content gap, v2 scope). Keeps
     editorial reading clean without empty-image-icon noise. -->
<script>
  (function () {
    const hideBroken = (img: HTMLImageElement) => {
      img.style.display = 'none'
    }
    document.addEventListener(
      'error',
      (e) => {
        const t = e.target as HTMLElement | null
        if (t && t.tagName === 'IMG' && t.closest('.prose')) {
          hideBroken(t as HTMLImageElement)
        }
      },
      true,
    )
    const sweep = () => {
      document.querySelectorAll<HTMLImageElement>('.prose img').forEach((img) => {
        if (img.complete && img.naturalWidth === 0) hideBroken(img)
        else img.addEventListener('error', () => hideBroken(img), { once: true })
      })
    }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', sweep, { once: true })
    } else {
      sweep()
    }
  })()
</script>

<!-- Scroll reveal for sections below the fold -->
<script>
  (function () {
    const reveals = document.querySelectorAll<HTMLElement>('.reveal')
    if (!reveals.length) return
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in-view')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.1 }
    )
    reveals.forEach((el) => observer.observe(el))
  })()
</script>

<style is:global>
  @import '../../styles/motion.css';

  /* ── Lede paragraph ──────────────────────────────────────── */
  .prose p.lede,
  .prose > p:first-of-type {
    font-size: var(--fs-xl);
    line-height: 1.6;
    color: var(--ink-2);
    margin-bottom: 1.6em;
    font-weight: 400;
  }

  /* ── Footnotes section ───────────────────────────────────── */
  .prose .footnotes,
  .prose section.footnotes {
    margin-top: var(--space-12);
    padding-top: var(--space-6);
    border-top: 1px solid var(--rule-soft);
  }

  .prose .footnotes ol {
    padding-left: 1.4em;
    list-style: decimal;
  }

  .prose .footnotes li {
    font-family: var(--f-serif);
    font-size: var(--fs-sm);
    color: var(--ink-3);
    line-height: 1.5;
    margin: 0.4em 0;
  }

  .prose .footnotes li::before {
    content: none;
  }

  .prose .footnotes p {
    margin: 0;
    display: inline;
  }

  /* ── TOC scroll-spy active state ─────────────────────────── */
  .reader-aside a.active {
    color: var(--ink);
    font-weight: 500;
  }
</style>

<style>
  /* ── EN-mode lang notice ─────────────────────────────────── */
  .lang-notice {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    font-style: italic;
    letter-spacing: 0.03em;
    margin: var(--space-4) 0;
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--rule-soft);
  }

  /* ── Reader layout ─────────────────────────────────────────── */
  .reader-layout {
    max-width: var(--w-page);
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-24);
    display: grid;
    grid-template-columns: 1fr var(--w-reader-side);
    gap: var(--space-12);
  }

  @media (max-width: 980px) {
    .reader-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .reader-aside {
      order: -1;
    }
  }

  /* ── Article header ────────────────────────────────────────── */
  .article-header {
    padding: var(--space-5) 0 var(--space-8);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-8);
  }

  .article-header .eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xxs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--space-3);
  }

  .article-header .kind-row {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-6);
    flex-wrap: wrap;
  }

  .article-header .meta {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    color: var(--ink-3);
    letter-spacing: var(--track-caption);
  }

  .article-header h1 {
    font-family: var(--f-disp);
    font-weight: 800;
    font-size: clamp(36px, 4vw, 52px);
    line-height: 1.05;
    margin: 0 0 var(--space-5);
    letter-spacing: -.02em;
    word-break: keep-all;
  }

  .article-header .tags {
    margin-top: var(--space-6);
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  /* ── Note prose — 52ch (narrower than post) ────────────────── */
  .note-prose {
    max-width: 52ch;
  }

  /* ── Reader aside ──────────────────────────────────────────── */
  .reader-aside {
    align-self: start;
    padding-top: var(--space-5);
  }

  /* TOC sticky during long reads — see posts/[slug].astro for full rationale. */
  .reader-aside :global(.toc) {
    position: sticky;
    top: 96px;
  }

  /* ── Page QA wrapper ───────────────────────────────────────── */
  .page-qa-wrapper {
    margin-top: var(--space-12);
  }

  /* ── Backlinks sidebar section ─────────────────────────────── */
  .backlinks-section {
    margin-bottom: 36px;
  }

  .backlinks-section .mono-eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xxs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    padding-bottom: 8px;
    margin-bottom: 10px;
    border-bottom: 1px solid var(--ink);
    font-weight: 400;
  }

  .backlinks-section ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .backlinks-section li {
    font-family: var(--f-serif);
    font-size: var(--fs-sm);
    padding: 5px 0;
    color: var(--ink-3);
    position: relative;
    padding-left: 18px;
    transition: color var(--dur-fast) var(--ease);
    line-height: 1.3;
  }

  .backlinks-section li::before {
    content: "‹";
    font-family: var(--f-mono);
    position: absolute;
    left: 0;
    color: var(--ink-4);
    font-size: var(--fs-xs);
  }

  .backlinks-section li:hover {
    color: var(--ink);
  }

  .backlinks-section a {
    color: inherit;
    text-decoration: none;
    display: block;
  }

  .backlinks-section a:hover {
    color: var(--ink);
    background: var(--paper);
  }

  .backlinks-section a:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* ── Related mesh sidebar section ──────────────────────────── */
  .related-mesh-section {
    margin-bottom: 36px;
  }

  .related-mesh-section .mono-eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xxs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink);
    padding-bottom: 8px;
    margin: 0 0 12px 0;
    border-bottom: 1px solid var(--ink);
    font-weight: 400;
  }

  .related-mesh-section .mesh-cta {
    display: block;
    margin-top: 10px;
    font-family: var(--f-mono);
    font-size: 11px;
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  .related-mesh-section .mesh-cta:hover {
    color: var(--ink);
  }

  .related-mesh-section .mesh-cta:focus-visible {
    outline: 2px solid var(--focus-ring);
    outline-offset: 2px;
  }

  /* Hide the graph + CTA on mobile; TOC stays in flow. */
  @media (max-width: 779px) {
    .related-mesh-section {
      display: none;
    }
  }
</style>
