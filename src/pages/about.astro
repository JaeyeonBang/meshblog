---
import Base from '../layouts/Base.astro'
import T from '../components/ui/atoms/T.astro'
---

<Base
  title="about · meshblog"
  description="Who built meshblog, what the coined terms mean, and why it is built this way."
  topBarActive="about"
>
  <article class="about-layout" id="about">
    <!-- ── Header ──────────────────────────────────────────────── -->
    <header class="about-header">
      <div class="eyebrow">about · 소개</div>
      <h1>meshblog</h1>
      <p class="sub">
        <T ko="재연 방의 이중언어 독서실 — 두 번째 뇌를 공개합니다." en="Jaeyeon Bang's bilingual reading room — a second brain made public." />
      </p>
    </header>

    <!-- ── Opening stanza ─────────────────────────────────────── -->
    <section class="about-section">
      <p class="about-body">
        <T ko="메모를 모으고, 개념을 잇고, 공개합니다." en="Collecting notes, linking concepts, making them public." />
      </p>
    </section>

    <!-- ── Coined terms glossary ───────────────────────────────── -->
    <section class="about-section" id="glossary" aria-labelledby="glossary-heading">
      <h2 class="section-eyebrow" id="glossary-heading"><T ko="용어" en="Coined terms" /></h2>
      <dl class="glossary">
        <div class="gloss-entry">
          <dt><strong>vault</strong> <span class="gloss-ko">볼트</span></dt>
          <dd>
            <T
              ko="노트 전체 컬렉션. content/notes/ 아래의 모든 파일."
              en="The full collection of notes — everything under content/notes/."
            />
          </dd>
        </div>

        <div class="gloss-entry">
          <dt><strong>concept mesh</strong> <span class="gloss-ko">개념 메시</span></dt>
          <dd>
            <T
              ko="노트에서 추출한 개념들의 그래프. 홈 사이드바와 graph · concept mode에서 볼 수 있다."
              en="Second-order graph of concepts extracted from notes. See it at graph · concept mode."
            />
          </dd>
        </div>

        <div class="gloss-entry">
          <dt><strong>backlinks</strong> <span class="gloss-ko">역링크</span></dt>
          <dd>
            <T
              ko="이 노트를 가리키는 다른 노트들. graph · backlinks에서 탐색할 수 있다."
              en="Inbound wikilinks — who pointed here. Explore at graph · backlinks."
            />
          </dd>
        </div>

        <div class="gloss-entry">
          <dt>
            <strong>L1 · 직접</strong> &nbsp;/&nbsp;
            <strong>L2 · 근처</strong> &nbsp;/&nbsp;
            <strong>L3 · 클러스터</strong>
          </dt>
          <dd>
            <T
              ko="그래프 깊이. L1은 직접 연결, L2는 2-hop, L3는 전체 클러스터."
              en="Graph depth. L1 direct links, L2 two-hop neighbors, L3 full community cluster."
            />
          </dd>
        </div>

        <div class="gloss-entry">
          <dt><strong>knowledge mesh</strong> <span class="gloss-ko">지식 메시</span></dt>
          <dd>
            <T
              ko="노트 + 개념 + 역링크를 모두 합친 전체 그래프."
              en="The full graph combining notes, concepts, and backlinks — every node and edge in the vault."
            />
          </dd>
        </div>

        <div class="gloss-entry">
          <dt><strong>ask the vault</strong> <span class="gloss-ko">볼트에 묻기</span></dt>
          <dd>
            <T
              ko="⌘K 검색 팔레트 — 노트와 Q&A 카드를 가로질러 답한다."
              en="The ⌘K search palette — answers across notes and Q&A cards."
            />
          </dd>
        </div>
      </dl>
    </section>

    <!-- ── Colophon ────────────────────────────────────────────── -->
    <section class="about-section" id="colophon" aria-labelledby="colophon-heading">
      <h2 class="section-eyebrow" id="colophon-heading"><T ko="콜로폰" en="Colophon" /></h2>
      <dl class="colophon-list">
        <div class="coloph-entry">
          <dt>Typefaces</dt>
          <dd>
            <a href="https://fonts.adobe.com/fonts/source-serif" target="_blank" rel="noopener">Source Serif 4</a>
            (display &amp; body) ·
            <a href="https://fonts.google.com/noto/specimen/Noto+Serif+KR" target="_blank" rel="noopener">Noto Serif KR</a>
            (Korean) ·
            Pretendard (UI sans) ·
            <a href="https://www.jetbrains.com/lp/mono/" target="_blank" rel="noopener">JetBrains Mono</a>
            (code &amp; labels)
          </dd>
        </div>

        <div class="coloph-entry">
          <dt>Stack</dt>
          <dd>
            <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> (static site) ·
            SQLite (local embeddings store) ·
            OpenAI embeddings (semantic search — degrades gracefully when key is absent) ·
            <a href="https://graphology.github.io" target="_blank" rel="noopener">Graphology</a>
            (graph data structure) · Deployed via GitHub Pages
          </dd>
        </div>

        <div class="coloph-entry">
          <dt>Source</dt>
          <dd>
            <a href="https://github.com/JaeyeonBang/meshblog" target="_blank" rel="noopener">
              github.com/JaeyeonBang/meshblog
            </a>
            — MIT license. Fork it, point it at your own Obsidian vault, run <code>claude /init</code>.
          </dd>
        </div>
      </dl>
    </section>
  </article>
</Base>

<style>
  /* ── About layout ──────────────────────────────────────────── */
  .about-layout {
    max-width: 60ch;
    margin: 0 auto;
    padding: 0 var(--space-8) var(--space-24);
  }

  /* ── Header ────────────────────────────────────────────────── */
  .about-header {
    padding: var(--space-12) 0 var(--space-10);
    border-bottom: 1px solid var(--ink);
    margin-bottom: var(--space-10);
  }

  .eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: var(--space-5);
  }

  .about-header h1 {
    font-family: var(--f-disp);
    font-weight: 600;
    font-size: var(--fs-5xl);
    margin: 0 0 var(--space-5);
    letter-spacing: -0.02em;
    line-height: 1;
    font-variation-settings: "opsz" 144;
  }

  .about-header .sub {
    font-family: var(--f-serif);
    font-size: var(--fs-xl);
    color: var(--ink-2);
    line-height: 1.5;
    margin: 0;
    font-weight: 400;
  }

  /* ── Sections ──────────────────────────────────────────────── */
  .about-section {
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--ink-5);
  }

  .about-section:last-child {
    border-bottom: 0;
  }

  .section-eyebrow {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-eyebrow);
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0 0 var(--space-6);
    font-weight: 400;
  }

  .about-body {
    font-family: var(--f-serif);
    font-size: var(--fs-lg);
    color: var(--ink-2);
    line-height: 1.65;
    margin: 0;
  }

  /* ── Glossary ──────────────────────────────────────────────── */
  .glossary {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .gloss-entry {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--ink-5);
  }

  .gloss-entry:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .glossary dt {
    font-family: var(--f-disp);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.01em;
  }

  .glossary dt strong {
    font-weight: 600;
  }

  .gloss-ko {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-nav);
    color: var(--ink-3);
    font-weight: 400;
    margin-left: var(--space-2);
  }

  .glossary dd {
    font-family: var(--f-serif);
    font-size: var(--fs-base);
    color: var(--ink-2);
    line-height: 1.65;
    margin: 0;
  }

  .glossary dd a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .glossary dd a:hover {
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
  }

  /* ── Colophon ──────────────────────────────────────────────── */
  .colophon-list {
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .coloph-entry {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--ink-5);
    display: grid;
    grid-template-columns: 8ch 1fr;
    gap: var(--space-4);
    align-items: baseline;
  }

  .coloph-entry:last-child {
    border-bottom: 0;
  }

  .colophon-list dt {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin: 0;
    padding-top: 2px;
  }

  .colophon-list dd {
    font-family: var(--f-serif);
    font-size: var(--fs-sm);
    color: var(--ink-2);
    line-height: 1.6;
    margin: 0;
  }

  .colophon-list dd a {
    color: var(--ink);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .colophon-list dd a:hover {
    background: var(--ink);
    color: var(--paper);
    text-decoration: none;
  }

  /* ── Inline code ───────────────────────────────────────────── */
  code {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--track-caption);
    color: var(--ink-3);
    background: var(--paper-2);
    padding: 2px 5px;
    border: 1px solid var(--ink-5);
  }

  /* ── Kbd ───────────────────────────────────────────────────── */
  kbd {
    font-family: var(--f-mono);
    font-size: var(--fs-xs);
    padding: 2px 6px;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--ink-5);
    letter-spacing: var(--track-caption);
  }

  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .about-layout {
      padding: 0 var(--space-5) var(--space-16);
    }

    .coloph-entry {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }
  }
</style>
